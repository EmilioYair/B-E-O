<!-- 
    HEADER PRINCIPAL 
    Este partial se usa en todas las páginas para mantener la consistencia.
    Usa clases definidas en /public/css/main.css
-->
<header class="app-header">

    <!-- SECCIÓN IZQUIERDA: NAVEGACIÓN Y PERFIL (Invertido) -->
    <div class="flex items-center gap-8">

        <div class="flex items-center gap-4 text-primary">
            <!-- Icono del logo -->
            <div class="size-10">
                <img src="/images/IconA.png" alt="Icono" class="w-10 h-10 object-contain inline-block">
            </div>
            <!-- Texto del logo -->
            <h2 class="app-logo-text">B E O</h2>
        </div>

        <!-- Enlaces de navegación -->
        <nav class="flex items-center gap-9">
            <a class="app-nav-link active" href="/">Inicio</a>
            <a class="app-nav-link" href="/encuentra">Encuentra</a>
            <a class="app-nav-link" href="/como_funciona">Como Funciona</a>
            
            <% if (typeof user !== 'undefined' && user) { %>
                <a class="app-nav-link" href="/dashboard">Dashboard</a>
            <% } else { %>
                <a class="app-nav-link" href="/login">Iniciar Sesion</a>
                <a class="app-nav-link" href="/registro">Registrarse</a>
            <% } %>
        </nav>

        <!-- Botón de acción principal -->
        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/postear" class="app-btn-primary">
                Postear un servicio
            </a>
        <% } %>
    </div>

    <!-- SECCIÓN DERECHA: LOGO Y BUSQUEDA (Invertido) -->
    <div class="flex flex-1 justify-end gap-8 items-center">
        <!-- BARRA DE BÚSQUEDA -->
        <label class="flex flex-col min-w-40 !h-10 max-w-64">
            <div class="app-search-container">
                <!-- Icono de lupa -->
                <div class="app-search-icon-wrapper">
                    <span class="material-symbols-outlined">search</span>
                </div>
                <!-- Input de texto -->
                <input class="app-search-input" placeholder="Buscar" value="" />
            </div>
        </label>

        <!-- Foto de perfil del usuario -->
        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/perfil" title="Ir a mi perfil">
                <div id="headerProfileImage" class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border border-primary/20"
                    data-alt="Worker profile photo"
                    style="background-image: url('<%= user.picture ? user.picture : '/images/DefaultProfile.png' %>');">
                </div>
            </a>
            <form action="/auth/logout" method="POST" class="ml-3">
                <button type="submit" class="px-3 py-2 rounded-lg bg-red-500 text-white hover:bg-red-600 transition">Cerrar Sesión</button>
            </form>
        <% } %>

    </div>
</header>

<script>
    // Corrección del bloque if para evitar errores de sintaxis
    const userId = '<%= typeof user !== "undefined" && user ? user.uid : "" %>';
    if (userId && document.getElementById('headerProfileImage')) {
        fetch(`/api/profile/${userId}/image-url`)
            .then(res => res.ok ? res.json() : Promise.reject())
            .then(data => {
                const avatarEL = document.getElementById('headerProfileImage');
                if (avatarEL && data.url) {
                    avatarEL.style.backgroundImage = `url("${data.url}")`;
                }
            })
            .catch(err => console.log('Avatar no encontrado, usando default'));
    }
</script>