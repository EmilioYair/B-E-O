<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Configuración</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed": "#002022",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed": "#012022",
                        "on-primary-container": "#117278",
                        "tertiary-fixed-dim": "#ffb68b",
                        "background": "#f6f8f8",
                        "primary": "#117278",
                        "on-tertiary": "#ffffff",
                        "on-primary-fixed-variant": "#004f54",
                        "error-container": "#ffdad6",
                        "tertiary-container": "#955830",
                        "primary-fixed": "#9ff0f6",
                        "primary-container": "#1172781a",
                        "tertiary": "#78411b",
                        "surface-container-low": "#f6f8f8",
                        "surface-container": "#ebeeee",
                        "secondary-fixed-dim": "#aeccce",
                        "on-surface": "#0f172a",
                        "surface-dim": "#d7dbda",
                        "on-tertiary-container": "#ffe1d1",
                        "surface": "#ffffff",
                        "on-tertiary-fixed-variant": "#6e3913",
                        "surface-container-highest": "#e0e3e3",
                        "on-secondary-container": "#4d696c",
                        "on-secondary": "#ffffff",
                        "on-error": "#ffffff",
                        "primary-fixed-dim": "#83d3da",
                        "inverse-on-surface": "#f6f8f8",
                        "surface-variant": "#f8fafc",
                        "secondary": "#476366",
                        "on-surface-variant": "#64748b",
                        "on-secondary-fixed-variant": "#2f4b4e",
                        "surface-bright": "#ffffff",
                        "surface-tint": "#117278",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e6e9e9",
                        "on-background": "#0f172a",
                        "secondary-fixed": "#c9e8eb",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#83d3da",
                        "secondary-container": "#c9e8eb",
                        "on-tertiary-fixed": "#321300",
                        "error": "#ba1a1a",
                        "inverse-surface": "#112021",
                        "outline-variant": "#e2e8f0",
                        "outline": "#117278",
                        "tertiary-fixed": "#ffdbc8"
                    },
                    fontFamily: {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
    </style>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="bg-background text-on-background min-h-screen flex flex-col">
    <%- include('../../Partials/header') %>
    <main class="flex-grow pt-24 pb-12 px-6 max-w-screen-xl mx-auto w-full">
        <header class="mb-8">
            <h1 class="text-3xl font-extrabold tracking-tight text-on-surface mb-2">Configuración</h1>
            <p class="text-on-surface-variant">Manage your account settings, notifications, and security preferences.
            </p>
        </header>
        <div class="flex flex-col md:flex-row gap-8">
            <aside class="w-full md:w-64 flex-shrink-0">
                <nav class="space-y-1">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-xl bg-primary-container text-primary font-semibold transition-all"
                        href="#">
                        <span class="material-symbols-outlined" data-icon="account_circle"
                            style="font-variation-settings: 'FILL' 1;">account_circle</span>
                        <span>Account</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-xl text-on-surface-variant hover:bg-surface-container-high transition-all"
                        href="#">
                        <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
                        <span>Notifications</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-xl text-on-surface-variant hover:bg-surface-container-high transition-all"
                        href="#">
                        <span class="material-symbols-outlined" data-icon="payments">payments</span>
                        <span>Payments</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-xl text-on-surface-variant hover:bg-surface-container-high transition-all"
                        href="#">
                        <span class="material-symbols-outlined" data-icon="shield">shield</span>
                        <span>Privacy</span>
                    </a>
                </nav>
                <div class="mt-8 p-4 bg-surface rounded-xl border border-primary/10 shadow-sm">
                    <p class="text-xs font-bold text-primary uppercase tracking-wider mb-2">Status</p>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-teal-500 animate-pulse"></div>
                        <span class="text-sm font-medium text-on-surface">Verified Professional</span>
                    </div>
                </div>
            </aside>
            <section class="flex-grow space-y-6">
                <div class="bg-surface rounded-xl border border-primary/10 shadow-sm overflow-hidden">
                    <div class="p-6 border-b border-outline-variant bg-surface-variant/30">
                        <h2 class="text-lg font-bold text-on-surface">Account Information</h2>
                        <p class="text-sm text-on-surface-variant">Update your personal details and security
                            credentials.</p>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide">Email
                                    Address</label>
                                <div class="relative">
                                    <input
                                        class="w-full px-4 py-2.5 rounded-lg border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-sm"
                                        type="email" value="artisan.pro@beoservice.com" />
                                    <button
                                        class="absolute right-3 top-2.5 text-primary text-xs font-bold hover:underline">Change</button>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide">Current
                                    Password</label>
                                <input
                                    class="w-full px-4 py-2.5 rounded-lg border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-sm"
                                    type="password" value="********" />
                            </div>
                        </div>
                        <div class="pt-4 border-t border-outline-variant">
                            <h3 class="text-sm font-bold text-on-surface mb-4">Security Preferences</h3>
                            <div class="flex items-center justify-between p-4 bg-surface-container-low rounded-lg">
                                <div>
                                    <p class="text-sm font-semibold text-on-surface">Two-Factor Authentication</p>
                                    <p class="text-xs text-on-surface-variant">Add an extra layer of security to your
                                        account.</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input checked="" class="sr-only peer" type="checkbox" value="" />
                                    <div
                                        class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary">
                                    </div>
                                </label>
                            </div>
                        </div>
                        <div class="pt-4 border-t border-outline-variant">
                            <div
                                class="bg-error-container/20 border border-error/10 p-4 rounded-lg flex items-start gap-4">
                                <span class="material-symbols-outlined text-error" data-icon="warning">warning</span>
                                <div>
                                    <h4 class="text-sm font-bold text-on-error-container">Danger Zone</h4>
                                    <p class="text-xs text-on-error-container/80 mb-3">Once you delete your account,
                                        there is no going back. Please be certain.</p>
                                    <button
                                        class="text-xs font-bold text-error hover:bg-error/10 px-3 py-1.5 rounded transition-colors border border-error/20">Delete
                                        Account</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="px-6 py-4 bg-slate-50/50 dark:bg-slate-900/20 flex justify-end gap-3">
                        <button
                            class="px-4 py-2 text-sm font-semibold text-on-surface-variant hover:text-on-surface transition-colors">Discard
                            Changes</button>
                        <button
                            class="px-6 py-2 bg-primary text-on-primary rounded-lg text-sm font-bold shadow-lg hover:brightness-110 active:scale-95 transition-all">Save
                            Account Details</button>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-surface rounded-xl border border-primary/10 shadow-sm p-6">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="p-2 bg-primary-container text-primary rounded-lg">
                                <span class="material-symbols-outlined" data-icon="credit_card">credit_card</span>
                            </span>
                            <h3 class="font-bold text-on-surface">Saved Methods</h3>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center justify-between p-3 border border-outline-variant rounded-lg">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-10 h-6 bg-slate-100 rounded flex items-center justify-center text-[10px] font-bold text-slate-400">
                                        VISA</div>
                                    <span class="text-sm font-medium text-on-surface">**** 4421</span>
                                </div>
                                <span
                                    class="text-[10px] font-bold text-on-surface-variant uppercase bg-surface-container-highest px-2 py-0.5 rounded">Primary</span>
                            </div>
                            <button
                                class="w-full py-2 border-2 border-dashed border-outline-variant rounded-lg text-xs font-bold text-on-surface-variant hover:border-primary/40 hover:text-primary transition-all">
                                + Add New Payment Method
                            </button>
                        </div>
                    </div>
                    <div class="bg-surface rounded-xl border border-primary/10 shadow-sm p-6">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="p-2 bg-tertiary/10 text-tertiary rounded-lg">
                                <span class="material-symbols-outlined" data-icon="visibility">visibility</span>
                            </span>
                            <h3 class="font-bold text-on-surface">Profile Visibility</h3>
                        </div>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-on-surface-variant">Public Portfolio</span>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input checked="" class="sr-only peer" type="checkbox" value="" />
                                    <div
                                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary">
                                    </div>
                                </label>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-on-surface-variant">Show availability status</span>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input checked="" class="sr-only peer" type="checkbox" value="" />
                                    <div
                                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary">
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('../../Partials/footer') %>
</body>

</html>