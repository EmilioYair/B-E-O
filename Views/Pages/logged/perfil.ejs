<!DOCTYPE html>
<html class="light" lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Perfil Público del Profesional</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#117278",
                        "background-light": "#f6f8f8",
                        "background-dark": "#112021",
                    },
                    fontFamily: { "display": ["Public Sans"] },
                    borderRadius: { "DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
</head>

<body class="font-display bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-100 min-h-screen">
    <%- include('../../Partials/header') %>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm overflow-hidden mb-8 border border-slate-100 dark:border-slate-800">
            <div class="h-48 bg-gradient-to-r from-primary/20 to-primary/5 relative">
                <div class="absolute -bottom-12 left-8 flex items-end gap-6">
                    <div class="w-32 h-32 rounded-xl border-4 border-white dark:border-slate-900 overflow-hidden shadow-lg bg-white">
                        <img id="profileImagePreview" alt="Foto de perfil" class="w-full h-full object-cover"
                            src="<%= user && user.picture ? user.picture : '/Images/default-avatar.png' %>" />
                    </div>
                    <div class="mb-4">
                        <div class="flex items-center gap-3">
                            <h1 id="profileNameDisplay" class="text-3xl font-bold">Cargando...</h1>
                            <div class="flex items-center gap-1.5 bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border border-primary/20">
                                <span class="material-icons text-sm">verified</span> Verificado
                            </div>
                        </div>
                        <p id="profileDescDisplay" class="text-slate-500 dark:text-slate-400 font-medium text-lg italic">Sin descripción disponible</p>
                    </div>
                </div>
            </div>
            
            <div class="pt-16 pb-6 px-8 flex justify-between items-center">
                <div class="flex gap-8">
                    <div class="flex flex-col">
                        <span class="text-slate-400 text-xs uppercase tracking-widest font-bold">Ubicación</span>
                        <span id="profileUbicacionDisplay" class="font-semibold flex items-center gap-1">
                            <span class="material-icons text-sm text-primary">location_on</span> No especificada
                        </span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-400 text-xs uppercase tracking-widest font-bold">Edad</span>
                        <span id="profileEdadDisplay" class="font-semibold">-- años</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-400 text-xs uppercase tracking-widest font-bold">Teléfono</span>
                        <span id="profileTelefonoDisplay" class="font-semibold">No especificado</span>
                    </div>
                </div>
                <button class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 font-semibold hover:bg-slate-50 transition-colors">
                    <span class="material-icons text-sm">share</span> Compartir
                </button>
            </div>

            <div class="border-t border-slate-200 dark:border-slate-800 p-6 bg-slate-50 dark:bg-slate-900 rounded-b-xl">
                <div class="space-y-6">
                    <div>
                        <h3 class="text-lg font-semibold mb-3">Actualizar foto de perfil</h3>
                        <form id="profileImageForm" class="flex flex-col sm:flex-row items-center gap-3">
                            <input id="profileImageInput" type="file" accept="image/*" class="px-3 py-2 border rounded-lg border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800" required />
                            <button type="submit" id="profileImageUploadBtn" class="bg-primary text-white px-4 py-2 rounded-lg font-bold hover:bg-[#0d5d62]">Subir foto</button>
                            <span id="profileImageStatus" class="text-sm font-medium"></span>
                        </form>
                    </div>

                    <div class="border-t border-slate-200 dark:border-slate-700"></div>

                    <div>
                        <h3 class="text-lg font-semibold mb-3">Información Personal</h3>
                        <form id="profileInfoForm" class="space-y-4">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <input id="profileNombre" type="text" placeholder="Nombre completo" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800" />
                                <input id="profileEdad" type="number" placeholder="Edad" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800" />
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <input id="profileTelefono" type="tel" placeholder="Teléfono" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800" />
                                <input id="profileUbicacion" type="text" placeholder="Ubicación (Ciudad/Colonia)" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800" />
                            </div>
                            <textarea id="profileBiografia" placeholder="Cuéntanos tu experiencia..." rows="3" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800"></textarea>
                            <input id="profileEspecialidades" type="text" placeholder="Especialidades (ej: Plomería, Electricidad)" class="w-full px-3 py-2 border rounded-lg dark:bg-slate-800" />
                            
                            <div class="flex items-center gap-4">
                                <button type="submit" id="profileInfoSubmitBtn" class="bg-primary text-white px-6 py-2 rounded-lg font-bold">Guardar Cambios</button>
                                <span id="profileInfoStatus" class="text-sm font-medium"></span>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-8">
                <section>
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-xl font-bold flex items-center gap-2">
                            <span class="material-icons text-primary">auto_awesome</span> Proyectos: Antes y Después
                        </h2>
                        <button onclick="document.getElementById('projectUploadForm').classList.toggle('hidden')" class="text-sm bg-primary/10 text-primary px-3 py-1 rounded-lg font-bold hover:bg-primary/20 transition-colors">
                            + Añadir Proyecto
                        </button>
                    </div>

                    <div id="projectUploadForm" class="hidden bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 rounded-xl mb-6 shadow-sm">
                        <h3 class="font-bold mb-3 text-sm uppercase text-slate-400">Nuevo Proyecto</h3>
                        <form id="newProjectForm" class="space-y-3 text-black">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="text-xs font-bold text-slate-500">Foto del Proyecto</label>
                                    <input id="projectImageInput" type="file" accept="image/*" class="w-full text-sm border rounded-lg p-2 mt-1 bg-white" required />
                                </div>
                                <div>
                                    <label class="text-xs font-bold text-slate-500">Descripción breve</label>
                                    <input id="projectDescInput" type="text" placeholder="Ej: Pintura de fachada" class="w-full text-sm border rounded-lg p-2 mt-1" required />
                                </div>
                            </div>
                            <div class="flex justify-end gap-2">
                                <button type="button" onclick="document.getElementById('projectUploadForm').classList.add('hidden')" class="px-4 py-2 text-sm font-semibold">Cancelar</button>
                                <button type="submit" id="saveProjectBtn" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-bold">Subir Proyecto</button>
                            </div>
                            <p id="projectStatus" class="text-xs mt-2 font-medium"></p>
                        </form>
                    </div>

                    <div id="projectsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="col-span-full py-10 text-center bg-white dark:bg-slate-900 rounded-xl border-2 border-dashed border-slate-200 dark:border-slate-800">
                            <p class="text-slate-400 italic">No hay proyectos para mostrar.</p>
                        </div>
                    </div>
                </section>

                <section class="space-y-4">
                    <h2 class="text-xl font-bold flex items-center gap-2">
                        <span class="material-icons text-primary">groups</span> Reseñas de Vecinos
                    </h2>
                    <div id="reviewsContainer" class="space-y-4">
                        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-100 dark:border-slate-800 text-center">
                            <p class="text-slate-500 italic">Este profesional aún no tiene reseñas de clientes.</p>
                        </div>
                    </div>
                </section>
            </div>

            <div class="space-y-6">
                <div class="bg-white dark:bg-slate-900 rounded-xl shadow-md border border-slate-100 dark:border-slate-800 p-6 sticky top-24">
                    <div class="text-center mb-6">
                        <div id="ratingNumber" class="text-5xl font-bold text-slate-900 dark:text-white mb-1">--</div>
                        <div class="flex justify-center text-slate-300 mb-2">
                            <span class="material-icons">star</span><span class="material-icons">star</span><span class="material-icons">star</span><span class="material-icons">star</span><span class="material-icons">star</span>
                        </div>
                        <p class="text-sm text-slate-500 font-medium">Sin calificaciones acumuladas</p>
                    </div>

                    <div class="space-y-4 mb-8">
                        <h4 class="text-sm font-bold text-slate-400 uppercase tracking-widest">Servicios Ofrecidos</h4>
                        <div id="profileEspecialidadesDisplay" class="flex flex-wrap gap-2">
                            <span class="text-xs text-slate-400 italic">No registradas</span>
                        </div>
                    </div>

                    <div class="bg-primary/5 border border-primary/20 rounded-xl p-6">
                        <h4 class="font-bold text-primary flex items-center gap-2 mb-3">
                            <span class="material-icons">shield</span> Compromiso B E O
                        </h4>
                        <ul class="space-y-3">
                            <li class="flex gap-3 text-sm text-slate-600 dark:text-slate-300">
                                <span class="material-icons text-primary text-sm">check_circle</span> Identidad validada.
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function loadProfileData() {
            const profileImage = document.getElementById('profileImagePreview');
            try {
                if (profileImage) {
                    const imgResponse = await fetch('/api/profile/<%= user.uid %>/image-url');
                    if (imgResponse.ok) {
                        const imgData = await imgResponse.json();
                        profileImage.src = imgData.url;
                    }
                }

                const infoResponse = await fetch('/api/profile/<%= user.uid %>/info');
                if (infoResponse.ok) {
                    const userData = await infoResponse.json();
                    if (userData.nombre) document.getElementById('profileNameDisplay').textContent = userData.nombre;
                    if (userData.biografia) document.getElementById('profileDescDisplay').textContent = userData.biografia;
                    if (userData.ubicacion) document.getElementById('profileUbicacionDisplay').textContent = userData.ubicacion;
                    if (userData.edad) document.getElementById('profileEdadDisplay').textContent = userData.edad + ' años';
                    if (userData.telefono) document.getElementById('profileTelefonoDisplay').textContent = userData.telefono;

                    document.getElementById('profileNombre').value = userData.nombre || '';
                    document.getElementById('profileEdad').value = userData.edad || '';
                    document.getElementById('profileTelefono').value = userData.telefono || '';
                    document.getElementById('profileBiografia').value = userData.biografia || '';
                    document.getElementById('profileUbicacion').value = userData.ubicacion || '';
                    if (userData.especialidades) {
                        document.getElementById('profileEspecialidades').value = userData.especialidades.join(', ');
                        const displayDiv = document.getElementById('profileEspecialidadesDisplay');
                        displayDiv.innerHTML = userData.especialidades.map(esp => 
                            `<span class="bg-primary/10 text-primary text-[10px] font-bold px-2 py-1 rounded-full uppercase border border-primary/20">${esp}</span>`
                        ).join('');
                    }
                }
            } catch (error) { console.error('Error:', error); }
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadProfileData();

            // SUBIR FOTO PERFIL
            document.getElementById('profileImageForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const fileInput = document.getElementById('profileImageInput');
                const status = document.getElementById('profileImageStatus');
                const btn = document.getElementById('profileImageUploadBtn');

                const formData = new FormData();
                formData.append('avatar', fileInput.files[0]);

                btn.disabled = true;
                status.textContent = "⏳ Subiendo...";
                status.className = "ml-3 text-blue-500 font-bold";

                try {
                    const res = await fetch('/api/profile/image', { method: 'PUT', credentials: 'include', body: formData });
                    if(res.ok) {
                        status.textContent = "✅ Actualizado con éxito";
                        status.className = "ml-3 text-green-600 font-bold";
                        setTimeout(() => window.location.reload(), 1000);
                    }
                } catch (err) { status.textContent = "❌ Error"; }
                finally { btn.disabled = false; }
            });

            // GUARDAR INFO PERSONAL
            document.getElementById('profileInfoForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const status = document.getElementById('profileInfoStatus');
                const btn = document.getElementById('profileInfoSubmitBtn');

                const payload = {
                    nombre: document.getElementById('profileNombre').value,
                    edad: document.getElementById('profileEdad').value,
                    telefono: document.getElementById('profileTelefono').value,
                    biografia: document.getElementById('profileBiografia').value,
                    ubicacion: document.getElementById('profileUbicacion').value,
                    especialidades: document.getElementById('profileEspecialidades').value.split(',').map(e => e.trim())
                };

                btn.disabled = true;
                status.textContent = "⏳ Guardando...";
                status.className = "text-blue-500 font-bold ml-2";

                try {
                    const res = await fetch('/api/profile/info', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(payload)
                    });
                    if(res.ok) {
                        status.textContent = "✅ Información actualizada con éxito";
                        status.className = "text-green-600 font-bold ml-2";
                        setTimeout(() => loadProfileData(), 1500);
                    }
                } catch (err) { status.textContent = "❌ Error"; }
                finally { btn.disabled = false; }
            });

            // SUBIR PROYECTO
            document.getElementById('newProjectForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const status = document.getElementById('projectStatus');
                const btn = document.getElementById('saveProjectBtn');
                const formData = new FormData();
                formData.append('projectImage', document.getElementById('projectImageInput').files);
                formData.append('descripcion', document.getElementById('projectDescInput').value);

                btn.disabled = true;
                status.textContent = "⏳ Subiendo proyecto...";
                status.className = "text-xs mt-2 text-blue-500 font-bold";

                try {
                    const res = await fetch('/api/profile/projects', { method: 'POST', credentials: 'include', body: formData });
                    if(res.ok) {
                        status.textContent = "✅ Proyecto subido con éxito";
                        status.className = "text-xs mt-2 text-green-600 font-bold";
                        setTimeout(() => window.location.reload(), 1500);
                    }
                } catch (err) { status.textContent = "❌ Error al subir"; }
                finally { btn.disabled = false; }
            });
        });
    </script>
    <%- include('../../Partials/footer') %>
</body>
</html>