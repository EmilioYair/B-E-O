                            <button id="profileImageUploadBtn" type="submit" class="bg-primary text-white px-4 py-2 rounded-lg font-bold hover:bg-[#0d5d62] transition">Subir foto</button>
                            <span id="profileImageStatus" class="text-sm text-slate-500"></span>
