    <script>
        // Cargar imagen de perfil y información al iniciar
        async function loadProfileData() {
            const profileImage = document.getElementById('profileImagePreview');
            
            try {
                // Cargar imagen
                if (profileImage) {
                    const imgResponse = await fetch('/api/profile/<%= user.uid %>/image-url');
                    if (imgResponse.ok) {
                        const imgData = await imgResponse.json();
                        profileImage.src = imgData.url;
                    }
                }

                // Cargar información del perfil
                const infoResponse = await fetch('/api/profile/<%= user.uid %>/info');
                if (infoResponse.ok) {
                    const userData = await infoResponse.json();
                    
                    // Actualizar datos en la página
                    if (userData.nombre) {
                        document.getElementById('profileNameDisplay').textContent = userData.nombre;
                    }
                    if (userData.biografia) {
                        document.getElementById('profileDescDisplay').textContent = userData.biografia;
                    }
                    if (userData.ubicacion) {
                        document.getElementById('profileUbicacionDisplay').textContent = userData.ubicacion;
                    }
                    if (userData.edad) {
                        document.getElementById('profileEdadDisplay').textContent = userData.edad + ' años';
                    }
                    if (userData.telefono) {
                        document.getElementById('profileTelefonoDisplay').textContent = userData.telefono;
                    }

                    // Llenar formulario con datos existentes
                    if (userData.nombre) document.getElementById('profileNombre').value = userData.nombre;
                    if (userData.edad) document.getElementById('profileEdad').value = userData.edad;
                    if (userData.telefono) document.getElementById('profileTelefono').value = userData.telefono;
                    if (userData.biografia) document.getElementById('profileBiografia').value = userData.biografia;
                    if (userData.ubicacion) document.getElementById('profileUbicacion').value = userData.ubicacion;
                    if (userData.especialidades && Array.isArray(userData.especialidades)) {
                        document.getElementById('profileEspecialidades').value = userData.especialidades.join(', ');
                    }
                }
            } catch (error) {
                console.error('Error al cargar datos del perfil:', error);
            }
        }

        // Cargar datos al iniciar página
        document.addEventListener('DOMContentLoaded', function () {
            loadProfileData();

            const form = document.getElementById('profileImageForm');
            const fileInput = document.getElementById('profileImageInput');
            const statusText = document.getElementById('profileImageStatus');
            const profileImage = document.getElementById('profileImagePreview');
            const submitBtn = document.getElementById('profileImageUploadBtn');

            if (!form) return;

            form.addEventListener('submit', async function (event) {
                event.preventDefault();

                if (!fileInput.files.length) {
                    statusText.textContent = 'Selecciona una imagen primero.';
                    return;
                }

                const file = fileInput.files[0];
                const formData = new FormData();
                formData.append('avatar', file);

                submitBtn.disabled = true;
                statusText.textContent = 'Subiendo...';

                try {
                    const response = await fetch('/api/profile/image', {
                        method: 'PUT',
                        credentials: 'include', // IMPORTANTE: enviar cookies de sesión
                        body: formData
                    });

                    if (!response.ok) {
                        const error = await response.json().catch(() => ({ error: 'Error desconocido' }));
                        throw new Error(error.error || 'No se pudo subir la imagen');
                    }

                    statusText.textContent = 'Obteniendo URL...';

                    // Obtener URL firmada para mostrar en preview
                    const urlResponse = await fetch('/api/profile/<%= user.uid %>/image-url');
                    if (!urlResponse.ok) {
                        throw new Error('No se pudo obtener la URL de la imagen');
                    }

                    const urlData = await urlResponse.json();
                    profileImage.src = urlData.url;
                    statusText.textContent = 'Foto actualizada correctamente';
                    fileInput.value = '';
                } catch (error) {
                    console.error(error);
                    statusText.textContent = 'Error: ' + (error.message || 'No se pudo subir la imagen');
                } finally {
                    submitBtn.disabled = false;
                }
            });

            // Manejar formulario de información del perfil
            const infoForm = document.getElementById('profileInfoForm');
            const infoSubmitBtn = document.getElementById('profileInfoSubmitBtn');
            const infoStatusText = document.getElementById('profileInfoStatus');

            if (infoForm) {
                infoForm.addEventListener('submit', async function (event) {
                    event.preventDefault();

                    const nombre = document.getElementById('profileNombre').value;
                    const edad = document.getElementById('profileEdad').value;
                    const telefono = document.getElementById('profileTelefono').value;
                    const biografia = document.getElementById('profileBiografia').value;
                    const ubicacion = document.getElementById('profileUbicacion').value;
                    const especialidades = document.getElementById('profileEspecialidades').value;

                    if (!nombre && !edad && !telefono && !biografia && !ubicacion && !especialidades) {
                        infoStatusText.textContent = 'Rellena al menos un campo.';
                        return;
                    }

                    infoSubmitBtn.disabled = true;
                    infoStatusText.textContent = 'Guardando...';

                    try {
                        const response = await fetch('/api/profile/info', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            credentials: 'include', // IMPORTANTE: enviar cookies de sesión
                            body: JSON.stringify({
                                nombre: nombre || undefined,
                                edad: edad || undefined,
                                telefono: telefono || undefined,
                                biografia: biografia || undefined,
                                ubicacion: ubicacion || undefined,
                                especialidades: especialidades ? especialidades.split(',').map(e => e.trim()) : undefined
                            })
                        });

                        console.log('Response status:', response.status);
                        console.log('Response headers:', response.headers.get('content-type'));

                        // Leer el response una sola vez como texto
                        const responseText = await response.text();
                        console.log('Response text:', responseText.substring(0, 500));

                        let responseData;
                        try {
                            responseData = JSON.parse(responseText);
                        } catch (jsonError) {
                            console.error('Error parsing JSON:', jsonError);
                            throw new Error(`Error ${response.status}: La respuesta no es JSON válido. Primeros 200 caracteres: ${responseText.substring(0, 200)}`);
                        }

                        if (!response.ok) {
                            throw new Error(responseData.error || `Error ${response.status}: ${responseData.details || 'Error desconocido'}`);
                        }

                        infoStatusText.textContent = 'Información guardada correctamente';
                        console.log('Respuesta del servidor:', responseData);
                        
                        // Recargar los datos mostrados
                        setTimeout(() => {
                            loadProfileData();
                            infoStatusText.textContent = '';
                        }, 1500);
                    } catch (error) {
                        console.error('Error completo:', error);
                        const errorMsg = error.message || 'Error al guardar la información';
                        infoStatusText.textContent = 'Error: ' + errorMsg;
                        
                        // Mostrar el error completo en un alert para que veas sin DevTools
                        alert('🔴 ERROR DETECTADO:\n\n' + errorMsg + '\n\nRevisa la página para más detalles.');
                    } finally {
                        infoSubmitBtn.disabled = false;
                    }
                });
            }
        });
    </script>
    <%- include('../../Partials/footer') %>
</body>

</html>