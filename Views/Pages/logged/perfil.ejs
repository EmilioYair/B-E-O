                    <div class="flex flex-col">
                        <span class="text-slate-400 text-xs uppercase tracking-widest font-bold">Ubicación</span>
                        <span id="profileUbicacionDisplay" class="font-semibold flex items-center gap-1">
                            <span class="material-icons text-sm text-primary">location_on</span>
