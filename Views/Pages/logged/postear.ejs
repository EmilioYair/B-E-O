<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#117278",
                        "background-light": "#f6f8f8",
                        "background-dark": "#112021",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <title>BEO Professionals - List a Service</title>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
        <div class="layout-container flex h-full grow flex-col">
            <!-- Header -->
            <header
                class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/10 bg-white dark:bg-background-dark px-6 md:px-20 py-3 sticky top-0 z-50">
                <div class="flex items-center gap-4 text-primary">
                    <div class="size-8 flex items-center justify-center bg-primary rounded-lg text-white">
                        <span class="material-symbols-outlined">construction</span>
                    </div>
                    <h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold leading-tight tracking-[-0.015em]">
                        BEO Professionals</h2>
                </div>
                <div class="flex flex-1 justify-end gap-8 items-center">
                    <nav class="hidden md:flex items-center gap-9">
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors"
                            href="#">Dashboard</a>
                        <a class="text-primary text-sm font-semibold" href="#">My Services</a>
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors"
                            href="#">Messages</a>
                    </nav>
                    <button
                        class="flex cursor-pointer items-center justify-center rounded-full h-10 w-10 bg-primary/10 text-primary hover:bg-primary/20 transition-all">
                        <span class="material-symbols-outlined text-[20px]">notifications</span>
                    </button>
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border-2 border-primary/20"
                        data-alt="Professional profile picture of a service provider"
                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCqlbhSaZMoSoFtgmBMMAyykism3IVhy81c5L-cCUjjpVziYGgDyjuVNeQmPDCqfFf-jZghM26CpuEcaqIY4vhsVih5OIPgPdqvBBKD1S6tQcZFB5qSXzDH3oX5-6HZ3kSVWCeggOvlaX20PqlDFK-3jPlYAQKZTNsLVs_fyMO9se2PqpRWlyDCgZ3ax9kNt0RnIhogFN0EB1N9w4zfGNqJ_2VELZjBmBMAJNb5EIJc6Wv7BScFA1wbWSk839V1IlGPxPdWVu1n24M");'>
                    </div>
                </div>
            </header>
            <main class="flex flex-1 justify-center py-8 px-4 md:px-0">
                <div class="layout-content-container flex flex-col max-w-[800px] flex-1">
                    <!-- Progress Header -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 mb-8 border border-primary/10 shadow-sm">
                        <div class="flex flex-col gap-4">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h1 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-slate-100">List a
                                        New Service</h1>
                                    <p class="text-slate-500 dark:text-slate-400 mt-1">Showcase your expertise to
                                        customers in San Juan del Río.</p>
                                </div>
                                <div class="hidden md:block text-right">
                                    <span
                                        class="text-xs font-bold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full">Step
                                        1 of 4</span>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <div class="flex justify-between items-center text-sm">
                                    <span class="font-medium text-slate-700 dark:text-slate-300">Service Details</span>
                                    <span class="text-primary font-bold">25% Complete</span>
                                </div>
                                <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-2.5">
                                    <div class="bg-primary h-2.5 rounded-full transition-all duration-500"
                                        style="width: 25%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Form Section 1: Details -->
                    <div class="space-y-8">
                        <section
                            class="bg-white dark:bg-slate-900 rounded-xl border border-primary/10 shadow-sm overflow-hidden">
                            <div
                                class="px-6 py-4 border-b border-primary/10 bg-slate-50/50 dark:bg-slate-800/50 flex items-center gap-3">
                                <span class="material-symbols-outlined text-primary">edit_note</span>
                                <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">1. Service Details</h2>
                            </div>
                            <div class="p-6 space-y-6">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="col-span-2">
                                        <label
                                            class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Service
                                            Title</label>
                                        <input
                                            class="w-full rounded-lg border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary py-3"
                                            placeholder="e.g. Professional Residential Plumbing &amp; Leak Repair"
                                            type="text" />
                                        <p class="text-xs text-slate-500 mt-1.5">A clear title helps customers find your
                                            service quickly.</p>
                                    </div>
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Category</label>
                                        <select
                                            class="w-full rounded-lg border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary py-3">
                                            <option>Select a category</option>
                                            <option selected="">Plumbing</option>
                                            <option>Electrical</option>
                                            <option>Carpentry</option>
                                            <option>Painting</option>
                                            <option>HVAC</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Sub-category</label>
                                        <select
                                            class="w-full rounded-lg border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary py-3">
                                            <option>Emergency Repairs</option>
                                            <option>Installation</option>
                                            <option>Maintenance</option>
                                        </select>
                                    </div>
                                    <div class="col-span-2">
                                        <label
                                            class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Description</label>
                                        <textarea
                                            class="w-full rounded-lg border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary"
                                            placeholder="Describe your service, experience, and what's included..."
                                            rows="4"></textarea>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- Section 2: Media -->
                        <section
                            class="bg-white dark:bg-slate-900 rounded-xl border border-primary/10 shadow-sm overflow-hidden opacity-60">
                            <div
                                class="px-6 py-4 border-b border-primary/10 bg-slate-50/50 dark:bg-slate-800/50 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-slate-400">photo_library</span>
                                    <h2 class="text-lg font-bold text-slate-400">2. Media Upload</h2>
                                </div>
                                <span class="material-symbols-outlined text-slate-300">lock</span>
                            </div>
                        </section>
                        <!-- Section 3: Pricing & Location Preview -->
                        <section
                            class="bg-white dark:bg-slate-900 rounded-xl border border-primary/10 shadow-sm overflow-hidden p-6">
                            <div class="flex flex-col md:flex-row gap-6">
                                <div class="flex-1 space-y-4">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-200">Service Location</h3>
                                    <div class="flex items-center gap-2 text-primary">
                                        <span class="material-symbols-outlined">location_on</span>
                                        <span class="font-medium">San Juan del Río, QRO</span>
                                    </div>
                                    <div
                                        class="h-40 w-full rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center relative overflow-hidden">
                                        <div class="absolute inset-0 bg-slate-200 animate-pulse"
                                            data-alt="Map showing service area in San Juan del Río"
                                            data-location="San Juan del Río"
                                            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD7dVz2AdH6OAfB3KvXGMXsaE-H8fKsEg--L9r5QqSpob9_iRUUtMFcr6Ot91FyqJUouvHA41-OMDigSvg4OrZwyHJdCzbwU4WTUoRAsS5140F_lCxSHp-cxBLvlTRab8ySbbVL6ytgzJMIW9Jvf3mraeQs6g9OGcjaiTlZ7BKyEZqXAPcW7NLJvskWBr3V-jq6lRk6_7IaTuVVUVZBWUQ9QLRTbq_2Unx4GcIaRCPmKgD5Ea6GpE8ibta9tTMp78F213awjNZkiTQ'); background-size: cover;">
                                        </div>
                                        <div
                                            class="z-10 bg-white/90 dark:bg-slate-900/90 px-3 py-1 rounded-full shadow-sm text-xs font-bold flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">my_location</span>
                                            Coverage Area
                                        </div>
                                    </div>
                                </div>
                                <div class="w-px bg-slate-100 dark:bg-slate-800 hidden md:block"></div>
                                <div class="flex-1 space-y-4">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-200">Pricing Model</h3>
                                    <div class="grid grid-cols-2 gap-3">
                                        <button class="border-2 border-primary bg-primary/5 p-4 rounded-xl text-center">
                                            <span class="material-symbols-outlined text-primary mb-1">payments</span>
                                            <p class="text-xs font-bold text-primary uppercase">Fixed Price</p>
                                        </button>
                                        <button
                                            class="border-2 border-slate-100 dark:border-slate-800 p-4 rounded-xl text-center hover:border-primary/30 transition-colors">
                                            <span class="material-symbols-outlined text-slate-400 mb-1">timer</span>
                                            <p class="text-xs font-bold text-slate-500 uppercase">Hourly Rate</p>
                                        </button>
                                    </div>
                                    <div>
                                        <div class="relative">
                                            <span
                                                class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                                            <input
                                                class="w-full pl-8 rounded-lg border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary py-3"
                                                placeholder="0.00" type="number" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                    <!-- Footer Actions -->
                    <div class="mt-10 flex items-center justify-between pb-20">
                        <button
                            class="px-6 py-3 rounded-xl font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex items-center gap-2">
                            <span class="material-symbols-outlined">arrow_back</span>
                            Save Draft
                        </button>
                        <div class="flex gap-4">
                            <button
                                class="px-8 py-3 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                                Next Step
                                <span class="material-symbols-outlined">arrow_forward</span>
                            </button>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</body>

</html>