<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Mensajes</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/main.css"> <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #117278; border-radius: 10px; }
        /* Ajuste para que el layout no se rompa con el header fixed y footer */
        .chat-layout { height: calc(100vh - 72px); } 
    </style>
</head>

<body class="bg-[#f6f8f8] text-[#0f172a] min-h-screen flex flex-col">
    
    <%- include('../../Partials/header') %>

    <main class="flex-1 flex flex-col mt-[72px]"> <div class="flex flex-1 overflow-hidden w-full chat-layout">
            
            <aside class="w-full md:w-[380px] border-r border-teal-500/10 bg-white flex flex-col shrink-0">
                <div class="p-4 border-b border-teal-500/5">
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                        <input id="userSearch" class="w-full pl-10 pr-4 py-2 bg-slate-50 border-none rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20" placeholder="Buscar trabajadores..." type="text" />
                    </div>
                </div>
                <div id="contactList" class="flex-1 overflow-y-auto custom-scrollbar">
                    <p class="p-8 text-center text-xs text-slate-400">Cargando trabajadores...</p>
                </div>
            </aside>

            <section class="flex-1 bg-white flex flex-col relative">
                <div id="activeChatHeader" class="hidden px-6 h-16 border-b border-teal-500/10 flex items-center justify-between bg-white/80 backdrop-blur-sm sticky top-0 z-10">
                    <div class="flex items-center gap-3">
                        <img id="activeUserImg" class="w-10 h-10 rounded-full object-cover border border-teal-500/20" src="/Images/default-avatar.png" />
                        <div>
                            <h2 id="activeUserName" class="font-bold text-slate-900 leading-none text-sm">---</h2>
                            <span class="text-[10px] text-teal-600 font-semibold flex items-center gap-1">En línea</span>
                        </div>
                    </div>
                </div>

                <div id="messagesArea" class="flex-1 overflow-y-auto p-6 space-y-4 bg-slate-50/30 custom-scrollbar flex flex-col">
                    <div class="m-auto text-center text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-2">forum</span>
                        <p class="text-sm">Selecciona un contacto para chatear</p>
                    </div>
                </div>

                <div class="p-6 bg-white border-t border-teal-500/10 mt-auto">
                    <form id="chatForm" class="flex items-center gap-4 bg-slate-50 p-2 rounded-2xl border border-teal-500/5">
                        <input id="msgInput" class="flex-1 bg-transparent border-none focus:ring-0 text-sm py-2 px-4" placeholder="Escribe un mensaje..." type="text" autocomplete="off" />
                        <button type="submit" class="bg-[#117278] text-white w-10 h-10 flex items-center justify-center rounded-xl shadow-lg hover:scale-105 active:scale-95 transition-all">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
                        </button>
                    </form>
                </div>
            </section>
        </div>
    </main>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, addDoc, query, orderBy, onSnapshot, serverTimestamp, getDocs, doc, getDoc } 
               from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBwrhj8kIqUbLhc4mHXA2MJmKOm1CpoNuI",
            authDomain: "b-e-o-798ec.firebaseapp.com",
            projectId: "b-e-o-798ec",
            storageBucket: "b-e-o-798ec.firebasestorage.app",
            messagingSenderId: "448375828376",
            appId: "1:448375828376:web:7c0ac31e17c4f6e4ec85ed",
            measurementId: "G-TM4ZCWEC5M"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const myId = "<%= user.uid || user.id %>"; 
        let currentRecipientId = null;
        let unsubscribeMessages = null;

        const formatTime = (date) => {
            if (!date) return "";
            return new Intl.DateTimeFormat('es-MX', { hour: '2-digit', minute: '2-digit', hour12: true }).format(date);
        };

        const loadContacts = async () => {
            const querySnapshot = await getDocs(collection(db, "users"));
            const contactList = document.getElementById('contactList');
            contactList.innerHTML = "";
            
            querySnapshot.forEach((doc) => {
                if(doc.id !== myId) {
                    const u = doc.data();
                    const fotoRuta = u.profileImagePath ? `/Images/${u.profileImagePath}` : '/Images/default-avatar.png';
                    const specs = u.especialidades ? u.especialidades.join(', ') : (u.ubicacion || 'San Juan del Río');
                    
                    const div = document.createElement('div');
                    div.className = "p-4 flex gap-4 cursor-pointer hover:bg-teal-50/50 transition-all border-l-4 border-transparent hover:border-teal-600";
                    div.id = `contact-${doc.id}`;
                    div.innerHTML = `
                        <img class="w-12 h-12 rounded-full object-cover border border-slate-100" 
                             src="${fotoRuta}" onerror="this.src='/Images/default-avatar.png'" />
                        <div class="flex-1 min-w-0">
                            <h3 class="font-bold text-sm text-slate-900 truncate">${u.nombre || 'Usuario'}</h3>
                            <p class="text-[11px] text-slate-500 truncate">${specs}</p>
                        </div>
                    `;
                    div.onclick = () => startChat(doc.id, u.nombre, fotoRuta);
                    contactList.appendChild(div);
                }
            });

            const urlParams = new URLSearchParams(window.location.search);
            const chatWithId = urlParams.get('chatWith');
            if (chatWithId) {
                const docRef = doc(db, "users", chatWithId);
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    const foto = data.profileImagePath ? `/Images/${data.profileImagePath}` : '/Images/default-avatar.png';
                    startChat(chatWithId, data.nombre, foto);
                }
            }
        };

        window.startChat = (recipientId, nombre, foto) => {
            currentRecipientId = recipientId;
            document.getElementById('activeChatHeader').classList.remove('hidden');
            document.getElementById('activeUserName').innerText = nombre;
            document.getElementById('activeUserImg').src = foto;
            
            document.querySelectorAll('#contactList > div').forEach(el => el.classList.remove('bg-teal-50/80', 'border-teal-600'));
            const activeDiv = document.getElementById(`contact-${recipientId}`);
            if(activeDiv) activeDiv.classList.add('bg-teal-50/80', 'border-teal-600');

            listenMessages(recipientId);
        };

        const listenMessages = (recipientId) => {
            if (unsubscribeMessages) unsubscribeMessages();
            const q = query(collection(db, "mensajes"), orderBy("createdAt", "asc"));

            unsubscribeMessages = onSnapshot(q, (snapshot) => {
                const area = document.getElementById('messagesArea');
                area.innerHTML = "";
                
                snapshot.forEach((doc) => {
                    const m = doc.data();
                    if ((m.enviadoPor === myId && m.recibidoPor === recipientId) || 
                        (m.enviadoPor === recipientId && m.recibidoPor === myId)) {
                        
                        const isMe = m.enviadoPor === myId;
                        const time = m.createdAt ? formatTime(m.createdAt.toDate()) : "";

                        area.innerHTML += `
                            <div class="flex ${isMe ? 'justify-end' : 'justify-start'} w-full">
                                <div class="max-w-[80%] flex flex-col ${isMe ? 'items-end' : 'items-start'}">
                                    <div class="${isMe ? 'bg-[#117278] text-white rounded-br-none' : 'bg-white text-slate-800 rounded-bl-none border'} p-3 rounded-2xl shadow-sm text-sm">
                                        ${m.texto}
                                    </div>
                                    <span class="text-[9px] text-slate-400 mt-1 px-1">${time}</span>
                                </div>
                            </div>
                        `;
                    }
                });
                area.scrollTop = area.scrollHeight;
            });
        };

        document.getElementById('chatForm').onsubmit = async (e) => {
            e.preventDefault();
            const input = document.getElementById('msgInput');
            if (input.value.trim() && currentRecipientId) {
                try {
                    await addDoc(collection(db, "mensajes"), {
                        texto: input.value.trim(),
                        enviadoPor: myId,
                        recibidoPor: currentRecipientId,
                        createdAt: serverTimestamp()
                    });
                    input.value = "";
                } catch (err) { console.error("Error al enviar:", err); }
            }
        };

        loadContacts();
    </script>
    <%- include('../../Partials/footer') %>
</body>
</html>