<!DOCTYPE html>

<html class="light" lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Mensajes</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed": "#002022",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed": "#012022",
                        "on-primary-container": "#117278",
                        "tertiary-fixed-dim": "#ffb68b",
                        "background": "#f6f8f8",
                        "primary": "#117278",
                        "on-tertiary": "#ffffff",
                        "on-primary-fixed-variant": "#004f54",
                        "error-container": "#ffdad6",
                        "tertiary-container": "#955830",
                        "primary-fixed": "#9ff0f6",
                        "primary-container": "#1172781a",
                        "tertiary": "#78411b",
                        "surface-container-low": "#f6f8f8",
                        "surface-container": "#ebeeee",
                        "secondary-fixed-dim": "#aeccce",
                        "on-surface": "#0f172a",
                        "surface-dim": "#d7dbda",
                        "on-tertiary-container": "#ffe1d1",
                        "surface": "#ffffff",
                        "on-tertiary-fixed-variant": "#6e3913",
                        "surface-container-highest": "#e0e3e3",
                        "on-secondary-container": "#4d696c",
                        "on-secondary": "#ffffff",
                        "on-error": "#ffffff",
                        "primary-fixed-dim": "#83d3da",
                        "inverse-on-surface": "#f6f8f8",
                        "surface-variant": "#f8fafc",
                        "secondary": "#476366",
                        "on-surface-variant": "#64748b",
                        "on-secondary-fixed-variant": "#2f4b4e",
                        "surface-bright": "#ffffff",
                        "surface-tint": "#117278",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e6e9e9",
                        "on-background": "#0f172a",
                        "secondary-fixed": "#c9e8eb",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#83d3da",
                        "secondary-container": "#c9e8eb",
                        "on-tertiary-fixed": "#321300",
                        "error": "#ba1a1a",
                        "inverse-surface": "#112021",
                        "outline-variant": "#e2e8f0",
                        "outline": "#117278",
                        "tertiary-fixed": "#ffdbc8"
                    },
                    fontFamily: {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
    </style>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="bg-background text-on-background min-h-screen flex flex-col">
    <%- include('../../Partials/header') %>
    <!-- Main Content Area: Split Screen Layout -->
    <main class="flex-1 pt-16 flex overflow-hidden max-w-screen-2xl mx-auto w-full">
        <!-- Left Column: Chat List -->
        <aside class="w-full md:w-[380px] border-r border-teal-500/10 bg-white flex flex-col h-[calc(100vh-64px)]">
            <div class="p-4 border-b border-teal-500/5">
                <div class="relative">
                    <span
                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                    <input
                        class="w-full pl-10 pr-4 py-2 bg-slate-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20 transition-all outline-none"
                        placeholder="Search conversations..." type="text" />
                </div>
            </div>
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <!-- Chat Item Active -->
                <div
                    class="p-4 flex gap-4 cursor-pointer bg-primary-container border-l-4 border-primary transition-colors">
                    <div class="relative shrink-0">
                        <img class="w-12 h-12 rounded-full object-cover"
                            data-alt="Professional headshot of a female artisan contractor in a workshop setting"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBgJPB95z5S23pJj_8o7zW_tVydiKjbW7aMPxDFaPsaGt8SUoBCjykSX6AP_q5Essrt8c3pPnKuA1d4EU9fHUx1zVV4NriPrt2__p2_6Ot8wDwpHkRtxGFsnYYOBpcjRivBLq6OA7N3oFheOyOyCjA2uK-C8MJITZhRFLMX-7iYKwadyUD0uSd03WTUBD5QsWXMRcMkweX8zoLrybm2UpWGkHJ2IjEAuFuuY0qyrli4b60sOATXTR83RvVEVIfAnl3ixjXALvsXqsQ" />
                        <span
                            class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white rounded-full"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-0.5">
                            <h3 class="font-bold text-slate-900 truncate">Elena Rodríguez</h3>
                            <span class="text-[10px] font-medium text-primary">14:20</span>
                        </div>
                        <p class="text-xs text-on-primary-container font-medium truncate">Perfecto, enviaré el
                            presupuesto actualizado esta tarde.</p>
                    </div>
                    <div class="flex flex-col items-end gap-1 shrink-0">
                        <span
                            class="bg-primary text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center">2</span>
                    </div>
                </div>
                <!-- Chat Item -->
                <div
                    class="p-4 flex gap-4 cursor-pointer hover:bg-slate-50 transition-colors border-l-4 border-transparent">
                    <div class="relative shrink-0">
                        <img class="w-12 h-12 rounded-full object-cover"
                            data-alt="Close up portrait of a male technician smiling in front of an industrial background"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCy4Tm2gys69pneOTnx6__IhQDUA13E4AYdGsFSOQef4af_N2O7xP8W5hqH7BCFrS5ntq24HzRfItnJzeqfX_rVvAGWJ3c92pdC6ITdFv5KIbBRq6TLpneHPzfLPHxlq2-bsU-3ouhwrKMyyUIgp3t9Ta3otwxzXohV6bnYQbS8kh5_uFWhGUtTPztyeV1hgg7k4jZQyYCXy3f-kiU1ifMw8RrjBqdER1gca1UP7Z2Zofl2sOVyerOMrhc6rpybA7Ll9Ykh46_irY4" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-0.5">
                            <h3 class="font-bold text-slate-900 truncate">Marco Tulio</h3>
                            <span class="text-[10px] text-slate-400">Yesterday</span>
                        </div>
                        <p class="text-xs text-slate-500 truncate">¿Podrías confirmar la dirección de entrega?</p>
                    </div>
                </div>
                <!-- Chat Item -->
                <div
                    class="p-4 flex gap-4 cursor-pointer hover:bg-slate-50 transition-colors border-l-4 border-transparent">
                    <div class="relative shrink-0">
                        <div
                            class="w-12 h-12 rounded-full bg-teal-100 flex items-center justify-center text-primary font-bold">
                            SM</div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-0.5">
                            <h3 class="font-bold text-slate-900 truncate">Suministros del Norte</h3>
                            <span class="text-[10px] text-slate-400">Tue</span>
                        </div>
                        <p class="text-xs text-slate-500 truncate">El pedido #4592 ha sido procesado correctamente.</p>
                    </div>
                </div>
                <!-- Chat Item -->
                <div
                    class="p-4 flex gap-4 cursor-pointer hover:bg-slate-50 transition-colors border-l-4 border-transparent">
                    <div class="relative shrink-0">
                        <img class="w-12 h-12 rounded-full object-cover"
                            data-alt="Portrait of a young professional woman with glasses in a modern office environment"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlC9lEVnbbRtwEBlPAUrNtPTfG62XTrZ6h_71w1vx0qPKub58WYKbJMqeDNt9blarivEcAzcpI1KuLShCP2v_vxYtUz8HP42Oo35F4DjzR85OOhhzVUq6huHfMAo1YbJBCw9tX1WJx0hLPCcBfhgopGfUhmwNGNsQm04WF70Pvkr-Ia2sHQs27fiuktRXr7wdgMq1ol7vbZaSAD7Hp4IGmu8IX59UAqoToKRWMMtC81etAK9T_DN4x6mjhtrATK9MVz3Xo67qRbMM" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-0.5">
                            <h3 class="font-bold text-slate-900 truncate">Carla Mendes</h3>
                            <span class="text-[10px] text-slate-400">22 Oct</span>
                        </div>
                        <p class="text-xs text-slate-500 truncate">¡Gracias por la rapidez en el servicio!</p>
                    </div>
                </div>
            </div>
        </aside>
        <!-- Right Column: Conversation Window -->
        <section class="flex-1 bg-white flex flex-col h-[calc(100vh-64px)] relative">
            <!-- Chat Header -->
            <div
                class="px-6 h-16 border-b border-teal-500/10 flex items-center justify-between bg-white/80 backdrop-blur-sm sticky top-0 z-10">
                <div class="flex items-center gap-3">
                    <img class="w-10 h-10 rounded-full object-cover"
                        data-alt="Female profile picture for active chat interface"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfsbiAoPm9qbs9CmTJZjkAMa8il0gDoU5yv0CqK2ScBn7iBvFTsYhMUfYTCLwz4IwHubrv3Ovl35isJFshrbOOIILqQpObYkaOV47T5EEpXcv1EDc0OtlhRlWdzW9AwNLz4ykeiefqVbJzm9qUtali952CWrHhAYbAanOH7DEMNZ_N0zOPnZEsPYOnSVSLBgBKg7uJMW1qhbHhul62p5Hlnes6XMv4SGmCD7SpvGqYEleS-ck_BXC56MdO9ak0tav_CEmRl7W__LM" />
                    <div>
                        <h2 class="font-bold text-slate-900 leading-none">Elena Rodríguez</h2>
                        <span class="text-[10px] text-green-600 font-semibold flex items-center gap-1">
                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Online
                        </span>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="p-2 text-slate-500 hover:bg-slate-100 rounded-full transition-all">
                        <span class="material-symbols-outlined">call</span>
                    </button>
                    <button class="p-2 text-slate-500 hover:bg-slate-100 rounded-full transition-all">
                        <span class="material-symbols-outlined">videocam</span>
                    </button>
                    <button class="p-2 text-slate-500 hover:bg-slate-100 rounded-full transition-all">
                        <span class="material-symbols-outlined">more_vert</span>
                    </button>
                </div>
            </div>
            <!-- Messages Area -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6 custom-scrollbar bg-slate-50/30">
                <div class="flex justify-center">
                    <span
                        class="text-[10px] font-bold tracking-widest text-slate-400 uppercase bg-white px-3 py-1 rounded-full shadow-sm border border-slate-100">Hoy</span>
                </div>
                <!-- Received Message -->
                <div class="flex items-end gap-3 max-w-[80%]">
                    <img class="w-8 h-8 rounded-full object-cover shrink-0 shadow-sm"
                        data-alt="Thumbnail of Elena for chat message"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBBKd3BISAMqkb8R8pcDP-tKnBkNWNu0BiOwK6a0D4vrCWZm-MjwZVBYpgem0FZd-7MwvSEM0vb9bYtKC08P1X7WkBDTVkHTCk2cgYtxA3XMFfduTB2l5PHF40e_KOd6B5PTK421XSf6Vh5CEV9CuF7J-SC5g4PC9JvXorccjzHwTUAutblROVBgwykgw5-PZ2racuiUaWDM3b8wDDwZpHEQ7BclGQcZY2qrm5OUE-PfV2h6xxEpdKNMTDR-mPUc5IMO9pMbPoRzc" />
                    <div class="group relative">
                        <div
                            class="bg-white border border-teal-500/10 p-4 rounded-xl rounded-bl-none shadow-sm text-sm text-slate-800 leading-relaxed">
                            Hola, ¿has tenido oportunidad de revisar los planos que te envié ayer para el proyecto de
                            reforma?
                        </div>
                        <span class="text-[10px] text-slate-400 mt-1 block px-1">14:15</span>
                    </div>
                </div>
                <!-- Sent Message -->
                <div class="flex items-end justify-end gap-3 ml-auto max-w-[80%]">
                    <div class="group relative text-right">
                        <div
                            class="bg-primary text-white p-4 rounded-xl rounded-br-none shadow-lg text-sm leading-relaxed">
                            Sí, Elena. Me parecen correctos. Solo tengo una duda sobre el material de los acabados en la
                            cocina.
                        </div>
                        <span class="text-[10px] text-slate-400 mt-1 block px-1">14:18 · Visto</span>
                    </div>
                </div>
                <!-- Received Message -->
                <div class="flex items-end gap-3 max-w-[80%]">
                    <img class="w-8 h-8 rounded-full object-cover shrink-0 shadow-sm"
                        data-alt="Thumbnail of Elena for chat message"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCNMzx8bkLo_kIx6D7kRit2rDIahj5zxdoUVZF3PRvWD2op6b-T01ZD1no11YDmkpYX3d4taB1XeI2-WNaDhgQhvC23pJm-GGqwrjdIEPn68qi9tQwI8faFHqrlcsrgPQhIgIJHUY3ZIhnLAMEzFZ5XWRlUoaJthuvUtHhsK-lr0Eg5i6CBJnxAdkQb32JVN881K9Qo_f0ZspnlRmVPKNnjtkgHpzsY7Ox16Msr6_uW2-EwuOK_Xa38ebCDowim7i7vP2XXGaNno2Q" />
                    <div class="group relative">
                        <div
                            class="bg-white border border-teal-500/10 p-4 rounded-xl rounded-bl-none shadow-sm text-sm text-slate-800 leading-relaxed">
                            Perfecto, enviaré el presupuesto actualizado esta tarde con las dos opciones de granito que
                            comentamos.
                        </div>
                        <span class="text-[10px] text-slate-400 mt-1 block px-1">14:20</span>
                    </div>
                </div>
            </div>
            <!-- Bottom Input Bar -->
            <div class="p-6 bg-white border-t border-teal-500/10">
                <div
                    class="flex items-center gap-4 bg-slate-50 p-2 rounded-2xl border border-teal-500/5 focus-within:ring-2 focus-within:ring-primary/10 transition-all">
                    <button class="p-2 text-primary hover:bg-primary/10 rounded-xl transition-all">
                        <span class="material-symbols-outlined">attach_file</span>
                    </button>
                    <input
                        class="flex-1 bg-transparent border-none focus:ring-0 text-sm py-2 px-2 text-slate-700 placeholder:text-slate-400"
                        placeholder="Type your message here..." type="text" />
                    <button class="p-2 text-slate-400 hover:text-primary transition-all">
                        <span class="material-symbols-outlined">sentiment_satisfied</span>
                    </button>
                    <button
                        class="bg-primary text-white w-10 h-10 flex items-center justify-center rounded-xl shadow-lg hover:brightness-110 active:scale-95 transition-all shrink-0">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
                    </button>
                </div>
            </div>
        </section>
    </main>
    <%- include('../../Partials/footer') %>
</body>

</html>