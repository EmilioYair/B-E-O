<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/main.css">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#117278",
                        "background-light": "#f6f8f8",
                        "background-dark": "#112021",
                    },
                    fontFamily: { "display": ["Inter"] },
                    borderRadius: { "DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <%- include('../../Partials/header') %>

        <div class="flex flex-1">
            <aside class="hidden w-64 flex-col border-r border-primary/10 bg-white dark:bg-background-dark p-6 lg:flex">
                <div class="mb-8 px-2">
                    <p class="text-xs font-semibold uppercase tracking-wider text-primary/60">Menú Principal</p>
                </div>
                <nav class="flex flex-col gap-2">
                    <a class="flex items-center gap-3 rounded-xl bg-primary px-4 py-3 text-white" href="/dashboard">
                        <span class="material-symbols-outlined">grid_view</span>
                        <span class="font-medium text-sm">Dashboard</span>
                    </a>
                    <a class="flex items-center gap-3 rounded-xl px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-primary/5 hover:text-primary transition-all" href="/postear">
                        <span class="material-symbols-outlined text-primary/60">add_box</span>
                        <span class="font-medium text-sm">Postear Servicio</span>
                    </a>
                    <a class="flex items-center gap-3 rounded-xl px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-primary/5 hover:text-primary transition-all" href="/mensajes">
                        <span class="material-symbols-outlined text-primary/60">chat_bubble</span>
                        <span class="font-medium text-sm">Mensajes</span>
                    </a>
                    <div class="my-4 border-t border-primary/5"></div>
                    <a class="flex items-center gap-3 rounded-xl px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-primary/5 hover:text-primary transition-all" href="/perfil">
                        <span class="material-symbols-outlined text-primary/60">person</span>
                        <span class="font-medium text-sm">Perfil Público</span>
                    </a>
                </nav>
            </aside>

            <main class="flex-1 overflow-y-auto p-6 lg:p-10">
                <div class="mx-auto max-w-6xl">
                    <div class="mb-8 flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                        <div>
                            <h1 class="text-3xl font-bold tracking-tight">
                                Bienvenido de nuevo, <%= (typeof user !== 'undefined' && user.nombre) ? user.nombre.split(' ') : 'Usuario' %>! 
                            </h1>
                            <p class="mt-1 text-slate-500">Panel de control de proveedor</p>
                        </div>
                        <div class="flex gap-3">
                            <a href="/postear" class="flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all active:scale-95">
                                <span class="material-symbols-outlined text-lg">add</span>
                                Publicar Servicio
                            </a>
                        </div>
                    </div>

                    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                        <div class="flex flex-col gap-1 rounded-2xl border border-primary/10 bg-white dark:bg-slate-800 p-6 shadow-sm">
                            <span class="text-sm font-medium text-slate-500 uppercase tracking-wider">Acuerdos Registrados</span>
                            <h3 class="mt-4 text-3xl font-bold text-slate-900 dark:text-white">
                                $<%= (typeof stats !== 'undefined') ? stats.ganancias : '0.00' %>
                            </h3>
                        </div>
                        <div class="flex flex-col gap-1 rounded-2xl border border-primary/10 bg-white dark:bg-slate-800 p-6 shadow-sm">
                            <span class="text-sm font-medium text-slate-500 uppercase tracking-wider">Servicios Activos</span>
                            <h3 class="mt-4 text-3xl font-bold text-slate-900 dark:text-white">
                                <%= (typeof stats !== 'undefined') ? stats.activos : '0' %>
                            </h3>
                        </div>
                        <div class="flex flex-col gap-1 rounded-2xl border border-primary/10 bg-white dark:bg-slate-800 p-6 shadow-sm">
                            <span class="text-sm font-medium text-slate-500 uppercase tracking-wider">Reputación</span>
                            <h3 class="mt-4 text-3xl font-bold text-slate-900 dark:text-white">
                                <%= (typeof stats !== 'undefined' && stats.rating) ? stats.rating : '—' %> ⭐
                            </h3>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                        <div class="lg:col-span-2">
                            <div class="mb-6 flex items-center justify-between">
                                <h2 class="text-xl font-bold tracking-tight">Gestión de Trabajos</h2>
                                <a href="/mis_servicios" class="text-sm font-semibold text-primary hover:underline">Ver todos</a>
                            </div>
                            <div class="flex flex-col gap-4">
                                <% if (typeof trabajos !== 'undefined' && trabajos.length > 0) { %>
                                    <% trabajos.forEach(job => { %>
                                        <div class="group flex flex-col gap-4 rounded-2xl border border-primary/5 bg-white dark:bg-slate-800 p-5 transition-all hover:border-primary/20 hover:shadow-md">
                                            <div class="flex items-start justify-between">
                                                <div class="flex items-center gap-4">
                                                    <div class="h-12 w-12 rounded-xl bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
                                                        <span class="material-symbols-outlined text-slate-400">assignment</span>
                                                    </div>
                                                    <div>
                                                        <h4 class="font-bold text-slate-900 dark:text-white"><%= job.titulo %></h4>
                                                        <p class="text-sm text-slate-500">Cliente: <%= job.cliente %></p>
                                                    </div>
                                                </div>
                                                <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-bold text-blue-700"><%= job.status %></span>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="flex flex-col items-center justify-center py-16 bg-white dark:bg-slate-800 rounded-2xl border-2 border-dashed border-slate-200 dark:border-slate-700 text-center px-4">
                                        <div class="bg-primary/5 p-4 rounded-full mb-4">
                                            <span class="material-symbols-outlined text-primary text-4xl">add_task</span>
                                        </div>
                                        <p class="text-slate-600 dark:text-slate-300 font-bold text-lg">No hay trabajos registrados</p>
                                        <p class="text-slate-400 text-sm mt-1 mb-6">Usa esta sección para llevar el control de tus acuerdos.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <div class="flex flex-col gap-8">
                            <section>
                                <h2 class="mb-4 text-xl font-bold tracking-tight">Monitor de Actividad</h2>
                                <div class="rounded-2xl border border-primary/10 bg-white dark:bg-slate-800 p-6 shadow-sm">
                                    <div class="mb-6 flex flex-col gap-4">
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs font-semibold text-slate-500 uppercase">Valor de Tratos</span>
                                            <span class="text-lg font-bold text-primary">$0.00</span>
                                        </div>
                                        
                                        <div class="space-y-2">
                                            <div class="flex justify-between text-[10px] font-bold uppercase text-slate-400">
                                                <span>Efectividad</span>
                                                <span>0%</span>
                                            </div>
                                            <div class="h-1.5 w-full rounded-full bg-slate-100 dark:bg-slate-700">
                                                <div class="h-full w-[0%] rounded-full bg-primary transition-all"></div>
                                            </div>
                                        </div>

                                        <div class="mt-2 space-y-3">
                                            <div class="flex items-center gap-3">
                                                <span class="material-symbols-outlined text-[18px] text-slate-300">task_alt</span>
                                                <span class="text-sm text-slate-400 dark:text-slate-500">0 Finalizados</span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="material-symbols-outlined text-[18px] text-slate-300">pending</span>
                                                <span class="text-sm text-slate-400 dark:text-slate-500">0 Pendientes</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <a href="/mis_servicios" class="w-full rounded-xl bg-primary/10 py-3 text-xs font-bold text-primary hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined text-sm">edit_note</span>
                                        REGISTRAR ACUERDO
                                    </a>
                                </div>
                            </section>

                            <section>
                                <h2 class="mb-4 text-xl font-bold tracking-tight">Actividad Reciente</h2>
                                <div class="space-y-4">
                                    <div class="flex gap-3 items-start opacity-60">
                                        <div class="size-2 rounded-full bg-slate-300 mt-1.5"></div>
                                        <p class="text-sm text-slate-400 italic">No hay actividad reciente para mostrar.</p>
                                    </div>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</body>
</html>