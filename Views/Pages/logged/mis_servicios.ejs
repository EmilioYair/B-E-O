<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#117278",
                        "on-primary": "#ffffff",
                        "background": "#f6f8f8",
                        "on-background": "#0f172a",
                        "surface": "#ffffff",
                        "on-surface": "#0f172a",
                        "on-surface-variant": "#64748b",
                        "outline-variant": "#e2e8f0",
                        "primary-container": "#e7f1f2",
                        "on-primary-container": "#083b3e",
                    },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>

<body class="bg-background text-on-background min-h-screen flex flex-col">
    <%- include('../../Partials/header') %>

    <div class="flex flex-1 max-w-screen-2xl mx-auto w-full">
        <aside class="hidden lg:flex flex-col w-64 h-[calc(100vh-4rem)] sticky top-16 p-4 border-r border-slate-200 bg-slate-50">
            <div class="pb-6">
                <div class="flex items-center gap-3 px-2 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center text-teal-700">
                        <span class="material-symbols-outlined">engineering</span>
                    </div>
                    <div>
                        <p class="text-lg font-bold text-slate-900 leading-tight">Panel Trabajador</p>
                    </div>
                </div>
                <nav class="space-y-1">
                    <a class="flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-slate-100 rounded-lg transition-all" href="/dashboard">
                        <span class="material-symbols-outlined">dashboard</span>
                        <span>Dashboard</span>
                    </a>
                    <a class="flex items-center gap-3 bg-teal-50 text-teal-700 font-semibold px-4 py-3 rounded-lg" href="/mis_servicios">
                        <span class="material-symbols-outlined">publish</span>
                        <span>Mis Servicios</span>
                    </a>
                </nav>
            </div>
        </aside>

        <main class="flex-1 p-6 md:p-8 lg:p-12">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
                <div>
                    <h1 class="text-3xl font-extrabold text-on-surface tracking-tight mb-2">Mis Servicios</h1>
                    <p class="text-on-surface-variant">Gestiona tus publicaciones y revisa tus trabajos.</p>
                </div>
                <a href="/postear" class="bg-primary text-on-primary px-6 py-3 rounded-xl font-bold hover:opacity-90 shadow-md flex items-center gap-2">
                    <span class="material-symbols-outlined">add_circle</span>
                    Nuevo servicio
                </a>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
                
                <div class="xl:col-span-2 space-y-6">
                    <div class="flex items-center justify-between mb-4 border-b border-outline-variant pb-2">
                        <h2 class="text-lg font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">bolt</span>
                            Publicados (<%= (typeof servicios !== 'undefined') ? servicios.length : 0 %>)
                        </h2>
                    </div>

                    <% if (typeof servicios !== 'undefined' && servicios.length > 0) { %>
                        <% servicios.forEach(servicio => { %>
                            <div class="group bg-white rounded-2xl border border-outline-variant hover:border-primary/50 hover:shadow-xl transition-all flex flex-col md:flex-row overflow-hidden">
                                <div class="w-full md:w-48 h-48 md:h-auto bg-slate-100">
                                    <img src="<%= servicio.imagenPath || 'https://via.placeholder.com/300' %>" class="w-full h-full object-cover" />
                                </div>
                                <div class="p-6 flex-1 flex flex-col justify-between">
                                    <div>
                                        <div class="flex justify-between items-start mb-2">
                                            <span class="px-2 py-1 rounded bg-teal-50 text-teal-700 text-[10px] font-bold uppercase">
                                                <%= servicio.activo ? 'Activo' : 'Pausado' %>
                                            </span>
                                            <span class="font-bold text-primary">$<%= servicio.precioBase %></span>
                                        </div>
                                        <h3 class="text-xl font-bold text-on-surface mb-2"><%= servicio.titulo %></h3>
                                        <p class="text-on-surface-variant text-sm line-clamp-2"><%= servicio.descripcion %></p>
                                    </div>
                                    <div class="flex items-center justify-between mt-6">
                                        <div class="flex items-center gap-4 text-[11px] font-semibold text-slate-500">
                                            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base text-slate-400">location_on</span> <%= servicio.ubicacion %></span>
                                        </div>
                                        <div class="flex gap-2">
                                            <button class="p-2 rounded-lg border border-outline-variant hover:bg-slate-50"><span class="material-symbols-outlined text-slate-600">edit</span></button>
                                            <button class="px-4 py-2 rounded-lg bg-slate-100 text-on-surface font-bold text-sm hover:bg-slate-200">
                                                <%= servicio.activo ? 'Pausar' : 'Activar' %>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="flex flex-col items-center justify-center py-20 border-2 border-dashed border-slate-200 rounded-3xl">
                            <span class="material-symbols-outlined text-5xl text-slate-200 mb-4">inventory_2</span>
                            <h3 class="text-lg font-bold text-slate-400">No has publicado servicios aún</h3>
                        </div>
                    <% } %>
                </div>

                <div class="space-y-6">
                    <div class="bg-white rounded-3xl p-6 border border-outline-variant shadow-sm">
                        <h2 class="text-lg font-bold flex items-center gap-2 mb-6">
                            <span class="material-symbols-outlined text-orange-500">pending</span>
                            Pendientes (<%= (typeof pendientes !== 'undefined') ? pendientes.length : 0 %>)
                        </h2>
                        
                        <% if (typeof pendientes !== 'undefined' && pendientes.length > 0) { %>
                            <% pendientes.forEach(p => { %>
                                <div class="p-4 rounded-xl mb-3 bg-slate-50 border border-slate-100">
                                    <p class="font-bold text-sm text-slate-800"><%= p.titulo %></p>
                                    <div class="w-full bg-slate-200 h-2 mt-3 rounded-full overflow-hidden">
                                        <div class="bg-orange-500 h-full rounded-full" style="width: 50%;"></div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-sm text-slate-400 text-center italic">Sin tareas en curso</p>
                        <% } %>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <%- include('../../Partials/footer') %>
</body>
</html>