<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Inicio</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&amp;display=swap"
        rel="stylesheet" />
    <!-- Material Symbols -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="/js/tailwind-config.js"></script>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        /* Custom scrollbar for horizontal scrolling sections */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-[#0d1b12] dark:text-gray-100 font-display transition-colors duration-200">
    <!-- Sticky Navigation Bar -->
    <!-- Sticky Navigation Bar -->
    <%- include('../../Partials/header') %>

        <!-- Hero Section -->
        <div class="relative w-full h-screen overflow-hidden flex flex-col justify-center">
            <!-- h-screen para ocupár la pantalla --->
            <!-- Background Image with Gradient Overlay -->
            <div class="absolute inset-0 bg-cover bg-center z-0"
                data-alt="Scenic view of San Juan del Río streets with colonial architecture"
                style='background-image: linear-gradient(rgba(16, 34, 22, 0.7), rgba(16, 34, 22, 0.5)), url("/Images/SanJunFondo.jpeg");'>
            </div>
            <div
                class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-20 flex flex-col items-center text-center">
                <!-- pt y pb son para el padding top y bottom -->
                <!-- 
                    Antiguo:
                    1. Elimina 'h-screen flex flex-col justify-center' del div padre (línea ~45).
                    2. Cambia 'pt-20 pb-20' aquí por 'pt-32 pb-48' 
                -->
                <h1
                    class="text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight mb-6 max-w-4xl">
                    Encuentra Expertos confiables en <br /><span class="text-secondary">San Juan del Río</span>
                </h1>
                <h2 class="text-gray-200 text-base sm:text-lg font-normal mb-10 max-w-2xl">
                    Conectando talentos locales con vecinos que necesitan ayudan.
                    Rapido y Seguro

                </h2>
                <!-- Search Component -->
                <div
                    class="w-full max-w-2xl bg-white dark:bg-[#1a3324] p-2 rounded-2xl shadow-2xl flex flex-col sm:flex-row gap-2 border border-gray-200 dark:border-gray-700">
                    <div class="flex-1 flex items-center px-4 h-12 sm:h-14">
                        <span class="material-symbols-outlined text-gray-400 mr-3">search</span>
                        <input
                            class="w-full bg-transparent border-none focus:ring-0 text-gray-800 dark:text-white placeholder-gray-400 text-base"
                            placeholder="¿Qué servicio necesitas? (ej. Electricista)" type="text" />
                    </div>
                    <div class="h-px sm:h-8 sm:w-px bg-gray-200 dark:bg-gray-600 my-auto hidden sm:block"></div>
                    <div
                        class="sm:w-48 flex items-center px-4 h-12 sm:h-14 border-t sm:border-t-0 border-gray-100 dark:border-gray-700">
                        <span class="material-symbols-outlined text-gray-400 mr-3">location_on</span>
                        <select
                            class="w-full bg-transparent border-none focus:ring-0 text-gray-800 dark:text-white text-base p-0 cursor-pointer">
                            <option>Centro</option>
                            <option>Zona Oriente</option>
                            <option>San Cayetano</option>
                            <option>Pedregoso</option>
                        </select>
                    </div>
                    <button
                        class="h-12 sm:h-full bg-primary hover:bg-green-400 text-[#ffffff] font-bold rounded-xl px-8 transition-colors sm:ml-auto w-full sm:w-auto mt-2 sm:mt-0">
                        Buscar
                    </button>
                </div>

            </div>
        </div>
        <!-- Popular Services Grid -->
        <section class="py-16 bg-background-light dark:bg-background-dark">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-[#0d1b12] dark:text-white">Servicios
                        Populares</h2>
                    <a class="text-sm font-semibold text-primary hover:underline flex items-center" href="/encuentra">
                        Ver todas las categorias
                        <span class="material-symbols-outlined text-lg ml-1">arrow_forward</span>
                    </a>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                    <!-- Card 1 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Plomeria">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">plumbing</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Plomeria</h3>
                    </a>
                    <!-- Card 2 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Electricidad">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">electrical_services</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Electricidad</h3>
                    </a>
                    <!-- Card 3 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Carpinteria">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">carpenter</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Carpintería</h3>
                    </a>
                    <!-- Card 4 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Limpieza">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">cleaning_services</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Limpieza</h3>
                    </a>
                    <!-- Card 5 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Mudanza">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">local_shipping</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Mudanza</h3>
                    </a>
                    <!-- Card 6 -->
                    <a class="group flex flex-col items-center p-6 rounded-xl bg-white dark:bg-[#1a2e22] border border-[#cfe7d7] dark:border-[#2d4a36] hover:border-primary dark:hover:border-primary hover:shadow-lg transition-all text-center"
                        href="/encuentra?categoria=Jardineria">
                        <div
                            class="size-12 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-primary mb-3 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">yard</span>
                        </div>
                        <h3 class="font-bold text-[#0d1b12] dark:text-gray-100">Jardinería</h3>
                    </a>
                </div>
            </div>
        </section>
        <!-- How It Works Section -->
        <section class="py-16 bg-white dark:bg-[#0c1a11]">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-[#0d1b12] dark:text-white mb-4">Simple, Seguro y Local.</h2>
                    <p class="text-gray-600 dark:text-gray-400">Te facilitamos encontrar ayuda o trabajar. Así funciona
                        para
                        nuestros vecinos.</p>
                </div>
                <div class="grid md:grid-cols-3 gap-8 relative">
                    <!-- Connector Line (Desktop) -->
                    <div class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-gray-100 dark:bg-gray-800 -z-0">
                    </div>
                    <!-- Step 1 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div
                            class="size-24 rounded-2xl bg-white dark:bg-[#1a2e22] border-4 border-green-50 dark:border-green-900/20 shadow-xl flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined text-4xl text-primary">search</span>
                        </div>
                        <h3 class="text-xl font-bold text-[#0d1b12] dark:text-white mb-3">1. Buscar y Filtrar</h3>
                        <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed px-4">
                            Explora perfiles verificados por oficio, ubicación o calificación. Filtra específicamente
                            para
                            barrios de San Juan del Río.
                        </p>
                    </div>
                    <!-- Step 2 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div
                            class="size-24 rounded-2xl bg-white dark:bg-[#1a2e22] border-4 border-green-50 dark:border-green-900/20 shadow-xl flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined text-4xl text-primary">chat</span>
                        </div>
                        <h3 class="text-xl font-bold text-[#0d1b12] dark:text-white mb-3">2. Chatea y Acuerda</h3>
                        <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed px-4">
                            Conecta directamente con profesionales. Discute detalles, comparte fotos del problema y
                            acuerda
                            un precio justo.
                        </p>
                    </div>
                    <!-- Step 3 -->
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <div
                            class="size-24 rounded-2xl bg-white dark:bg-[#1a2e22] border-4 border-green-50 dark:border-green-900/20 shadow-xl flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined text-4xl text-primary">verified</span>
                        </div>
                        <h3 class="text-xl font-bold text-[#0d1b12] dark:text-white mb-3">3. Contrata con Confianza</h3>
                        <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed px-4">
                            Haz que se realice el trabajo. Califica a tu profesional después para ayudar a mantener
                            nuestra
                            comunidad de confianza y alta calidad.
                        </p>
                    </div>
                </div>
            </div>
        </section>
        <!-- Call to Action for Workers -->
        <section class="py-20 bg-background-light dark:bg-background-dark">
            <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
                <div
                    class="bg-primary rounded-3xl p-8 sm:p-12 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8">
                    <!-- Pattern Overlay -->
                    <div class="absolute inset-0 opacity-10"
                        style="background-image: radial-gradient(#0d1b12 1px, transparent 1px); background-size: 20px 20px;">
                    </div>
                    <div class="relative z-10 max-w-lg">
                        <h2 class="text-3xl font-black text-[#ffffff] mb-4">¿Eres un Profesional Capacitado?</h2>
                        <p class="text-[#ffffff]/80 text-lg font-medium mb-0">
                            Únete a cientos de expertos locales que hacen crecer su negocio en San Juan del Río. Es
                            gratis
                            unirse.
                        </p>
                    </div>
                    <div class="relative z-10 shrink-0">
                        <a href="/registro"
                            class="inline-block bg-[#0d1b12] text-white hover:bg-gray-900 px-8 py-4 rounded-xl font-bold text-lg transition-transform hover:scale-105 shadow-xl">
                            Únete como Profesional
                        </a>
                    </div>
                </div>
            </div>
        </section>
        <!-- Footer -->
        <%- include('../../Partials/footer') %>
        <script>
            document.addEventListener('DOMContentLoaded', async () => {
                const container = document.getElementById('popularServices');
                if(!container) return;
                
                try {
                    const response = await fetch('/api/services');
                    const services = await response.json();
                    
                    if (!Array.isArray(services) || services.length === 0) {
                        container.innerHTML = `<div class="col-span-full text-center py-12"><p class="text-gray-500 italic">${!Array.isArray(services) ? 'Error al cargar servicios.' : 'No hay servicios disponibles en este momento.'}</p></div>`;
                        return;
                    }
                    
                    container.innerHTML = services.map(service => `
                        <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all group flex flex-col h-full border border-gray-100">
                            <div class="relative h-48 overflow-hidden bg-gray-100">
                                <img src="${service.imagenUrl || '/Images/default-avatar.png'}" alt="${service.titulo}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm uppercase tracking-wider">${service.categoria}</div>
                            </div>
                            <div class="p-6 flex-grow flex flex-col">
                                <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-[#117278] transition-colors">${service.titulo}</h3>
                                <p class="text-gray-500 text-sm mb-4 line-clamp-2 flex-grow">${service.descripcion}</p>
                                <div class="flex items-center gap-2 text-sm text-gray-500 mt-auto">
                                    <span class="material-symbols-outlined text-[18px]">location_on</span>
                                    <span>${service.ubicacion || 'San Juan del Río'}</span>
                                </div>
                            </div>
                            <div class="p-6 pt-0 border-t border-gray-50 flex items-center justify-between">
                                <div>
                                    <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Precio Base</p>
                                    <p class="text-[#117278] font-black text-lg">$${service.precioBase}</p>
                                </div>
                                <button class="bg-[#117278]/10 text-[#117278] hover:bg-[#117278] hover:text-white size-12 rounded-xl flex items-center justify-center transition-all">
                                    <span class="material-symbols-outlined font-bold">arrow_forward</span>
                                </button>
                            </div>
                        </div>
                    `).join('');
                } catch (error) {
                    console.error('Error fetching services:', error);
                    container.innerHTML = '<div class="col-span-full text-center py-12 text-red-500 font-bold">Error al cargar servicios. Verifica tu conexión o base de datos.</div>';
                }
            });
        </script>
</body>
</html>