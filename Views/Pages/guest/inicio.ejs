                                Ver Todos
                                <span class="material-symbols-outlined text-lg">arrow_forward</span>
                            </a>
                        </div>
                        <!-- Jobs List -->
                        <div id="popularServices" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            <!-- Se cargarán dinámicamente -->
                            <div class="col-span-full text-center py-12">
                                <p class="text-gray-500 italic">Descubriendo los mejores servicios para ti...</p>
                            </div>
                        </div>
                    </div>
        </section>
        <!-- Call to Action for Workers -->
        <section class="py-20 bg-background-light dark:bg-background-dark">
            <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
                <div
                    class="bg-primary rounded-3xl p-8 sm:p-12 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8">
                    <!-- Pattern Overlay -->
                    <div class="absolute inset-0 opacity-10"
                        style="background-image: radial-gradient(#0d1b12 1px, transparent 1px); background-size: 20px 20px;">
                    </div>
                    <div class="relative z-10 max-w-lg">
                        <h2 class="text-3xl font-black text-[#ffffff] mb-4">¿Eres un Profesional Capacitado?</h2>
                        <p class="text-[#ffffff]/80 text-lg font-medium mb-0">
                            Únete a cientos de expertos locales que hacen crecer su negocio en San Juan del Río. Es
                            gratis
                            unirse.
                        </p>
                    </div>
                    <div class="relative z-10 shrink-0">
                        <a href="/registro"
                            class="inline-block bg-[#0d1b12] text-white hover:bg-gray-900 px-8 py-4 rounded-xl font-bold text-lg transition-transform hover:scale-105 shadow-xl">
                            Únete como Profesional
                        </a>
                    </div>
                </div>
            </div>
        </section>
        <!-- Footer -->
        <%- include('../../Partials/footer') %>
        <script>
            document.addEventListener('DOMContentLoaded', async () => {
                const container = document.getElementById('popularServices');
                if(!container) return;
                
                try {
                    const response = await fetch('/api/services');
                    const services = await response.json();
                    
                    if (services.length === 0) {
                        container.innerHTML = '<div class="col-span-full text-center py-12"><p class="text-gray-500 italic">No hay servicios disponibles en este momento.</p></div>';
                        return;
                    }
                    
                    container.innerHTML = services.map(service => `
                        <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all group flex flex-col h-full border border-gray-100">
                            <div class="relative h-48 overflow-hidden bg-gray-100">
                                <img src="${service.imagenUrl || '/images/DefaultService.png'}" alt="${service.titulo}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm uppercase tracking-wider">${service.categoria}</div>
                            </div>
                            <div class="p-6 flex-grow flex flex-col">
                                <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-[#117278] transition-colors">${service.titulo}</h3>
                                <p class="text-gray-500 text-sm mb-4 line-clamp-2 flex-grow">${service.descripcion}</p>
                                <div class="flex items-center gap-2 text-sm text-gray-500 mt-auto">
                                    <span class="material-symbols-outlined text-[18px]">location_on</span>
                                    <span>${service.ubicacion || 'San Juan del Río'}</span>
                                </div>
                            </div>
                            <div class="p-6 pt-0 border-t border-gray-50 flex items-center justify-between">
                                <div>
                                    <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Precio Base</p>
                                    <p class="text-[#117278] font-black text-lg">$${service.precioBase}</p>
                                </div>
                                <button class="bg-[#117278]/10 text-[#117278] hover:bg-[#117278] hover:text-white size-12 rounded-xl flex items-center justify-center transition-all">
                                    <span class="material-symbols-outlined font-bold">arrow_forward</span>
                                </button>
                            </div>
                        </div>
                    `).join('');
                } catch (error) {
                    console.error('Error fetching services:', error);
                    container.innerHTML = '<div class="col-span-full text-center py-12 text-red-500 font-bold">Error al cargar servicios. Verifica tu conexión o base de datos.</div>';
                }
            });
        </script>
</body>
</html>