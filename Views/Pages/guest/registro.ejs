<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Registro | B E O - San Juan del Río Marketplace</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#117278",
                        "background-light": "#f6f8f8",
                        "background-dark": "#112021",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    <script>
        const firebaseConfig = {
            apiKey: "<%= process.env.FIREBASE_API_KEY %>",
            authDomain: "<%= process.env.FIREBASE_AUTH_DOMAIN %>",
            projectId: "<%= process.env.FIREBASE_PROJECT_ID %>",
            storageBucket: "<%= process.env.FIREBASE_STORAGE_BUCKET %>",
            messagingSenderId: "<%= process.env.FIREBASE_MESSAGING_SENDER_ID %>",
            appId: "<%= process.env.FIREBASE_APP_ID %>"
        };
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
    </script>
</head>

<body class="bg-background-light dark:bg-background-dark min-h-screen flex flex-col font-display">
    <div class="flex-1 flex flex-col md:flex-row min-h-screen">
        <div class="hidden md:flex md:w-1/2 relative flex-col justify-between p-12 overflow-hidden bg-primary">
            <div class="absolute inset-0 z-0">
                <div class="absolute inset-0 bg-primary/40 mix-blend-multiply z-10"></div>
                <img alt="San Juan del Rio, Registro" class="w-full h-full object-cover"
                    data-alt="Beautiful aerial view of San Juan del Rio city center" src="/images/FotoRegistro.png" />
            </div>
            <div class="relative z-20">
                <div class="flex items-center gap-3 text-white">
                    <div class="size-12 rounded-lg flex items-center justify-center overflow-hidden">
                        <img src="/images/IconA.png" alt="BEO Logo" class="w-full h-full object-contain">
                    </div>
                    <h1 class="text-3xl font-black tracking-tighter">B E O</h1>
                </div>
            </div>
            <div class="relative z-20 text-white max-w-md">
                <h2 class="text-5xl font-extrabold leading-tight mb-6">Conectando<br>San Jua del Rio</h2>
                <p class="text-lg text-white/90 leading-relaxed">
                    Unete al mejor servicio local de oficios.<br>Si estas buscando a un experto o buscando<br>compartir tus habilidades, B E O es tu lugar.
                </p>
            </div>
            <div class="relative z-20 text-white/60 text-sm">
                © 2024 B E O . All rights reserved.
            </div>
        </div>
        <div
            class="flex-1 flex flex-col items-center justify-center p-6 md:p-12 lg:p-20 bg-background-light dark:bg-background-dark">
            <div class="w-full max-w-md space-y-8">
                <div class="md:hidden flex justify-center mb-8">
                    <div class="flex items-center gap-2 text-primary">
                        <img src="/images/IconA.png" alt="BEO Logo" class="w-10 h-10 object-contain">
                        <span class="text-2xl font-black">B E O</span>
                    </div>
                </div>
                <div class="space-y-2 text-center md:text-left">
                    <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-100">Crea una Cuenta</h2>
                    <p class="text-slate-500 dark:text-slate-400">Unete a nuestra comunidad hoy y empieza a crecer.</p>
                </div>
                <div class="flex p-1 bg-primary/10 dark:bg-primary/20 rounded-xl">
                    <button
                        class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-lg bg-white dark:bg-slate-800 shadow-sm text-primary font-semibold text-sm transition-all">
                        <span class="material-symbols-outlined text-xl">person</span>
                        Estoy Buscando
                    </button>
                    <button
                        class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-lg text-slate-600 dark:text-slate-400 font-medium text-sm hover:text-primary transition-all">
                        <span class="material-symbols-outlined text-xl">handyman</span>
                        Estoy Ofreciendo
                    </button>
                </div>
                <form id="registerForm" class="space-y-5">
                    <div class="space-y-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300 ml-1">Nombre Completo</label>
                        <div class="relative">
                            <span
                                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">person</span>
                            <input id="nombre"
                                class="w-full pl-12 pr-4 py-3.5 rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                placeholder="Rafael Zaragoza" type="text" required />
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300 ml-1">Correo Electronico</label>
                        <div class="relative">
                            <span
                                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
                            <input id="email"
                                class="w-full pl-12 pr-4 py-3.5 rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                placeholder="nombre@ejemplo.com" type="email" required />
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300 ml-1">Numero Telefonico</label>
                        <div class="relative">
                            <span
                                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">call</span>
                            <input
                                class="w-full pl-12 pr-4 py-3.5 rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                placeholder="+52 (427) 000 0000" type="tel" />
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300 ml-1">Contraseña</label>
                        <div class="relative">
                            <span
                                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                            <input id="password"
                                class="w-full pl-12 pr-12 py-3.5 rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                placeholder="••••••••" type="password" required />
                            <button id="togglePasswordBtn" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary"
                                type="button">
                                <span id="togglePasswordIcon" class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 py-2">
                        <input class="mt-1 rounded text-primary focus:ring-primary" id="terms" type="checkbox" />
                        <label class="text-sm text-slate-500 dark:text-slate-400" for="terms">
                            Al crear una cuenta, Acepto a los <a class="text-primary font-semibold hover:underline"
                                href="#">Terminos de Servicio</a> y <a class="text-primary font-semibold hover:underline"
                                href="#">Politicas de Privacidad</a>.
                        </label>
                    </div>
                    <button
                        class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-2"
                        type="submit">
                        Crea una Cuenta
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </form>
                <div class="text-center">
                    <p class="text-slate-600 dark:text-slate-400">
                        Ya tienes cuenta?
                        <a class="text-primary font-bold hover:underline" href="/login">Iniciar Sesion</a>
                    </p>
                </div>
            </div>
            <footer
                class="mt-auto pt-10 border-t border-slate-200 dark:border-slate-800 w-full max-w-md flex flex-wrap justify-center gap-x-8 gap-y-2">
                <a class="text-xs font-medium text-slate-400 hover:text-primary transition-colors uppercase tracking-widest"
                    href="#">POLITICA DE PRIVACIDAD</a>
                <a class="text-xs font-medium text-slate-400 hover:text-primary transition-colors uppercase tracking-widest"
                    href="#">TERMINOS DE SERVICIO</a>
                <a class="text-xs font-medium text-slate-400 hover:text-primary transition-colors uppercase tracking-widest"
                    href="#">AYUDA</a>
            </footer>
        </div>
    </div>
    <script>
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const nombre = document.getElementById('nombre').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            // Podrías agregar el campo esTrabajador si el usuario lo selecciona en la UI

            try {
                // 1. Crear usuario en Firebase Auth
                const userCredential = await auth.createUserWithEmailAndPassword(email, password);
                const user = userCredential.user;

                // 2. Sincronizar datos adicionales con el backend (Firestore)
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        uid: user.uid,
                        nombre,
                        email,
                        esTrabajador: false // Valor por defecto o dinámico
                    })
                });

                if (response.ok) {
                    alert('Registro exitoso de ' + user.email + '. Por favor inicia sesión.');
                    window.location.href = '/login';
                } else {
                    const errorData = await response.json();
                    alert('Error al guardar datos de perfil: ' + errorData.error);
                }
            } catch (error) {
                console.error('Error de registro:', error);
                alert('Error al crear cuenta: ' + error.message);
            }
        });
    </script>
    <script>
        const togglePasswordBtn = document.getElementById('togglePasswordBtn');
        const passwordInput = document.getElementById('password');
        const togglePasswordIcon = document.getElementById('togglePasswordIcon');

        if (togglePasswordBtn && passwordInput) {
            togglePasswordBtn.addEventListener('click', () => {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                togglePasswordIcon.textContent = type === 'password' ? 'visibility' : 'visibility_off';
            });
        }
    </script>
</body>

</html>