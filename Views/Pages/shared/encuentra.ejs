<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O Job Search Board</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="/js/tailwind-config.js"></script>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <!-- Top Navigation Bar -->
        <%- include('../../Partials/header') %>
            <main class="flex-1 flex justify-center py-8">
                <div class="flex w-full max-w-[1280px] px-6 gap-8">
                    <!-- Sidebar Navigation (Filters) -->
                    <aside class="w-64 flex flex-col shrink-0">
                        <div
                            class="flex flex-col gap-6 bg-white dark:bg-background-dark p-6 rounded-xl border border-[#e8f2f3] dark:border-primary/20 shadow-sm">
                            <div class="flex flex-col">
                                <h1 class="text-[#0e1a1b] dark:text-white text-lg font-bold leading-normal">Filters</h1>
                                <p class="text-[#509295] text-sm font-normal leading-normal">Narrow your search</p>
                            </div>
                            <div class="flex flex-col gap-2">
                                <div
                                    class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] dark:hover:bg-primary/10 rounded-lg transition-colors group">
                                    <span
                                        class="material-symbols-outlined text-primary group-hover:scale-110">location_on</span>
                                    <p class="text-[#0e1a1b] dark:text-gray-200 text-sm font-medium leading-normal">
                                        Distance
                                        from me</p>
                                </div>
                                <div
                                    class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/10 border border-primary/20">
                                    <span class="material-symbols-outlined text-primary">handyman</span>
                                    <p class="text-primary text-sm font-bold leading-normal">Trade Type</p>
                                </div>
                                <div
                                    class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] dark:hover:bg-primary/10 rounded-lg transition-colors group">
                                    <span
                                        class="material-symbols-outlined text-primary group-hover:scale-110">payments</span>
                                    <p class="text-[#0e1a1b] dark:text-gray-200 text-sm font-medium leading-normal">
                                        Budget
                                        Range</p>
                                </div>
                                <div
                                    class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] dark:hover:bg-primary/10 rounded-lg transition-colors group">
                                    <span
                                        class="material-symbols-outlined text-primary group-hover:scale-110">alarm</span>
                                    <p class="text-[#0e1a1b] dark:text-gray-200 text-sm font-medium leading-normal">
                                        Urgency
                                        Level</p>
                                </div>
                            </div>
                            <div class="pt-4 border-t border-[#e8f2f3] dark:border-primary/20">
                                <p
                                    class="text-[#0e1a1b] dark:text-white text-xs font-bold uppercase tracking-wider mb-3">
                                    Popular Trades</p>
                                <div class="flex flex-col gap-2">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input checked="" class="rounded text-primary focus:ring-primary h-4 w-4"
                                            type="checkbox" />
                                        <span class="text-sm text-[#0e1a1b] dark:text-gray-300">Plomería</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input class="rounded text-primary focus:ring-primary h-4 w-4"
                                            type="checkbox" />
                                        <span class="text-sm text-[#0e1a1b] dark:text-gray-300">Electricidad</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input class="rounded text-primary focus:ring-primary h-4 w-4"
                                            type="checkbox" />
                                        <span class="text-sm text-[#0e1a1b] dark:text-gray-300">Albañilería</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </aside>
                    <!-- Main Content Area -->
                    <div class="flex-1 flex flex-col gap-4">
                        <!-- Page Heading -->
                        <div
                            class="flex flex-wrap justify-between items-end gap-3 p-4 bg-white dark:bg-background-dark rounded-xl border border-[#e8f2f3] dark:border-primary/20 shadow-sm">
                            <div class="flex min-w-72 flex-col gap-1">
                                <p class="text-primary text-4xl font-black leading-tight tracking-[-0.033em]">Job Board
                                </p>
                                <p class="text-[#509295] text-base font-normal leading-normal">Available service leads
                                    in
                                    San Juan del Río</p>
                            </div>
                            <button
                                class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-10 px-4 bg-[#e8f2f3] dark:bg-primary/10 text-primary text-sm font-bold leading-normal border border-primary/20">
                                <span class="material-symbols-outlined text-sm mr-2">refresh</span>
                                <span class="truncate">Refresh List</span>
                            </button>
                        </div>
                        <!-- Chips / Active Filters -->
                        <div class="flex gap-3 px-4 py-2 flex-wrap items-center">
                            <p class="text-[#509295] text-xs font-bold uppercase tracking-wider mr-2">Active:</p>
                            <button
                                class="flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-full bg-primary/10 border border-primary/20 pl-4 pr-2 hover:bg-primary/20">
                                <p class="text-primary text-sm font-medium">Plomería</p>
                                <span class="material-symbols-outlined text-[18px] text-primary">close</span>
                            </button>
                            <button
                                class="flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-full bg-primary/10 border border-primary/20 pl-4 pr-2 hover:bg-primary/20">
                                <p class="text-primary text-sm font-medium">San Cayetano</p>
                                <span class="material-symbols-outlined text-[18px] text-primary">close</span>
                            </button>
                            <button
                                class="flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-full bg-primary/10 border border-primary/20 pl-4 pr-2 hover:bg-primary/20">
                                <p class="text-primary text-sm font-medium">Urgent</p>
                                <span class="material-symbols-outlined text-[18px] text-primary">close</span>
                            </button>
                            <button class="text-xs text-primary font-bold hover:underline ml-2">Clear all</button>
                        </div>
                        <!-- Jobs List -->
                        <div class="flex flex-col gap-6">
                            <!-- Card 1 -->
                            <div class="@container">
                                <div
                                    class="flex flex-col items-stretch justify-start rounded-xl @xl:flex-row @xl:items-start shadow-sm border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark hover:shadow-md transition-shadow overflow-hidden">
                                    <div class="w-full @xl:w-64 bg-center bg-no-repeat aspect-video @xl:aspect-square bg-cover"
                                        data-alt="Plumbing leak repair visual"
                                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBz27rpeLwVGI45irb_0viN-ug1VOhqQjzLfywcCx5SHKYOUl_nUJ1NIrk6LqJDqGtXtW-IiIDPAbI4Ciwx3DOZ-1gnssG5INXcQGvT2LOg8ojbvaYhnnlFH_NA10-E53C71NPsT8e0EwEBP0KfOcNSxBzcxzVO1mdtVorb-hmTeQ6ffZeu-ciEiB2Z0Eb-tLXPIimcHQlEgGR6U4q-n7-zL1oLH0Bruoizxc_Jlbx-pZbbLrnk6QdbHVEC8KGKrpZHTgheGRcnmF0");'>
                                    </div>
                                    <div
                                        class="flex w-full min-w-72 grow flex-col items-stretch justify-center gap-3 py-6 px-6">
                                        <div class="flex justify-between items-start">
                                            <div class="flex flex-col">
                                                <p class="text-primary text-xs font-bold uppercase tracking-wider">
                                                    Category:
                                                    Plomería</p>
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-xl font-black leading-tight tracking-[-0.015em]">
                                                    Plomería - Fuga de agua</p>
                                            </div>
                                            <span
                                                class="bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 px-3 py-1 rounded-full text-xs font-bold">ALTA
                                                URGENCIA</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-[#509295]">
                                            <span class="material-symbols-outlined text-sm">location_on</span>
                                            <p class="text-sm font-medium">San Cayetano, San Juan del Río</p>
                                        </div>
                                        <p
                                            class="text-[#509295] dark:text-gray-400 text-base font-normal leading-relaxed line-clamp-2">
                                            Se requiere reparación urgente de tubería principal en cocina. El agua se
                                            está
                                            filtrando por debajo del gabinete.
                                        </p>
                                        <div
                                            class="flex items-center justify-between mt-2 pt-4 border-t border-[#e8f2f3] dark:border-primary/20">
                                            <div class="flex flex-col">
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-lg font-bold leading-tight">
                                                    $500 - $1,200 MXN</p>
                                                <p class="text-[#509295] text-xs">Presupuesto estimado</p>
                                            </div>
                                            <button
                                                class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-10 px-4 bg-primary text-white text-sm font-bold shadow-sm hover:bg-primary/90">
                                                <span class="truncate">Apply to Bid</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Card 2 -->
                            <div class="@container">
                                <div
                                    class="flex flex-col items-stretch justify-start rounded-xl @xl:flex-row @xl:items-start shadow-sm border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark hover:shadow-md transition-shadow overflow-hidden">
                                    <div class="w-full @xl:w-64 bg-center bg-no-repeat aspect-video @xl:aspect-square bg-cover"
                                        data-alt="Electrical fuse box repair"
                                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDiLKvO6tfc7tSZWnjNJgOZ_bGNyibbiXABG39PljIp7r35Tmy-V6fAHCdVNmEr1HAbAaIQdxWm8xJ5XWiHvbftoApxSPvBo-U6Xn6iw54t6NnCUtU9dZTPIMvY0FpFpqyfoa3Rc8UlxULkdDmOn0G4zILDOw4VNyQeN_6foYFRqrwv7a4MCQNnPDCxCmY-oDDBXftumYMRFBeWREM9Tnyi4jmBZmE2Gcf0JM_lIMkM_1gw9rld9dQQ01Nhe0KIF-T8E5ilOqSo5mA");'>
                                    </div>
                                    <div
                                        class="flex w-full min-w-72 grow flex-col items-stretch justify-center gap-3 py-6 px-6">
                                        <div class="flex justify-between items-start">
                                            <div class="flex flex-col">
                                                <p class="text-primary text-xs font-bold uppercase tracking-wider">
                                                    Category:
                                                    Electricidad</p>
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-xl font-black leading-tight tracking-[-0.015em]">
                                                    Cortocircuito en sala</p>
                                            </div>
                                            <span
                                                class="bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 px-3 py-1 rounded-full text-xs font-bold">MEDIA</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-[#509295]">
                                            <span class="material-symbols-outlined text-sm">location_on</span>
                                            <p class="text-sm font-medium">Lomas de San Juan, SJR</p>
                                        </div>
                                        <p
                                            class="text-[#509295] dark:text-gray-400 text-base font-normal leading-relaxed line-clamp-2">
                                            Las luces de la sala parpadean y un contacto huele a quemado. Necesito
                                            revisión
                                            completa del cableado.
                                        </p>
                                        <div
                                            class="flex items-center justify-between mt-2 pt-4 border-t border-[#e8f2f3] dark:border-primary/20">
                                            <div class="flex flex-col">
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-lg font-bold leading-tight">
                                                    $800 - $1,500 MXN</p>
                                                <p class="text-[#509295] text-xs">Presupuesto estimado</p>
                                            </div>
                                            <button
                                                class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-10 px-4 bg-primary text-white text-sm font-bold shadow-sm">
                                                <span class="truncate">Apply to Bid</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Card 3 -->
                            <div class="@container">
                                <div
                                    class="flex flex-col items-stretch justify-start rounded-xl @xl:flex-row @xl:items-start shadow-sm border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark hover:shadow-md transition-shadow overflow-hidden">
                                    <div class="w-full @xl:w-64 bg-center bg-no-repeat aspect-video @xl:aspect-square bg-cover"
                                        data-alt="Wall repair and masonry"
                                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuD38MFkUCwHdkNtZZlILlbrDw7FQPg1mewb0jpNMbV7Rc2qDgspKrBpZt5lUxjjx0yZbKO1IFh91izvq2XhxSCyC6jkVsv5PF_H_wUQOpAdY2bG2MECDlzQYNVqZVamfbD3fDpqM7iiRQlnnQzMeflivbLfcLKRx53GfxtEUP5r2K-qxZTO2mPxEHdpq-vs1HFkeYCzZCpY-N8YvhheyMowqBR_vXU5LN_bg7mStZUqh8aGctutgfOFLdKlL89sr09bCK9BH7Z0vQM");'>
                                    </div>
                                    <div
                                        class="flex w-full min-w-72 grow flex-col items-stretch justify-center gap-3 py-6 px-6">
                                        <div class="flex justify-between items-start">
                                            <div class="flex flex-col">
                                                <p class="text-primary text-xs font-bold uppercase tracking-wider">
                                                    Category:
                                                    Albañilería</p>
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-xl font-black leading-tight tracking-[-0.015em]">
                                                    Reparación de barda</p>
                                            </div>
                                            <span
                                                class="bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 px-3 py-1 rounded-full text-xs font-bold">BAJA</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-[#509295]">
                                            <span class="material-symbols-outlined text-sm">location_on</span>
                                            <p class="text-sm font-medium">Centro, SJR</p>
                                        </div>
                                        <p
                                            class="text-[#509295] dark:text-gray-400 text-base font-normal leading-relaxed line-clamp-2">
                                            Pequeño tramo de barda trasera necesita ser reforzado y repellado por caída
                                            de
                                            escombro.
                                        </p>
                                        <div
                                            class="flex items-center justify-between mt-2 pt-4 border-t border-[#e8f2f3] dark:border-primary/20">
                                            <div class="flex flex-col">
                                                <p
                                                    class="text-[#0e1a1b] dark:text-white text-lg font-bold leading-tight">
                                                    $1,500 - $3,000 MXN</p>
                                                <p class="text-[#509295] text-xs">Presupuesto estimado</p>
                                            </div>
                                            <button
                                                class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-10 px-4 bg-primary text-white text-sm font-bold shadow-sm">
                                                <span class="truncate">Apply to Bid</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Pagination -->
                        <div class="flex justify-center p-8">
                            <nav class="flex items-center gap-2">
                                <button
                                    class="size-10 flex items-center justify-center rounded-lg border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark text-primary">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </button>
                                <button
                                    class="size-10 flex items-center justify-center rounded-lg bg-primary text-white font-bold">1</button>
                                <button
                                    class="size-10 flex items-center justify-center rounded-lg border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark text-[#0e1a1b] dark:text-white">2</button>
                                <button
                                    class="size-10 flex items-center justify-center rounded-lg border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark text-[#0e1a1b] dark:text-white">3</button>
                                <span class="px-2 text-[#509295]">...</span>
                                <button
                                    class="size-10 flex items-center justify-center rounded-lg border border-[#e8f2f3] dark:border-primary/20 bg-white dark:bg-background-dark text-primary">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </button>
                            </nav>
                        </div>
                    </div>
                </div>
            </main>
    </div>
</body>

</html>