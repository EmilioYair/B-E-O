<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Encuentra Servicios</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .bg-beo { background-color: #00797a; }
        .text-beo { color: #00797a; }
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .modal-animate { animation: fadeIn 0.2s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <%- include('../../Partials/header') %>
        
        <main class="flex-1 flex justify-center py-8">
            <div class="flex w-full max-w-[1280px] px-6 gap-8">
                <aside class="w-64 flex flex-col shrink-0 sticky top-20">
                    <div class="flex flex-col gap-6 bg-white p-6 rounded-xl border border-[#e8f2f3] shadow-sm">
                        <h2 class="text-[#0e1a1b] text-lg font-bold">Filtros</h2>
                        <div class="flex flex-col gap-2">
                            <button id="btnLocation" class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] rounded-lg transition-colors group">
                                <span class="material-symbols-outlined text-beo">location_on</span>
                                <p class="text-[#0e1a1b] text-sm font-medium">Ubicación</p>
                            </button>
                            <button id="btnPrice" class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] rounded-lg transition-colors group">
                                <span class="material-symbols-outlined text-beo">payments</span>
                                <p class="text-[#0e1a1b] text-sm font-medium">Precio Máximo</p>
                            </button>
                        </div>
                        <div class="flex flex-col gap-2 border-t pt-4">
                            <p class="text-xs font-bold text-gray-400 mb-2 uppercase">Oficios Populares</p>
                            <% ['Plomería', 'Electricidad', 'Albañilería', 'Carpintería', 'Mecánica', 'Herrería'].forEach(oficio => { %>
                                <label class="flex items-center gap-2 cursor-pointer hover:text-beo">
                                    <input name="trade" value="<%= oficio %>" type="checkbox" class="rounded text-beo focus:ring-beo border-slate-300">
                                    <span class="text-sm text-[#0e1a1b]"><%= oficio %></span>
                                </label>
                            <% }) %>
                        </div>
                    </div>
                </aside>

                <div class="flex-1 flex flex-col gap-4">
                    <div class="flex flex-wrap justify-between items-end gap-3 p-6 bg-white rounded-xl border border-[#e8f2f3] shadow-sm">
                        <div>
                            <p class="text-beo text-4xl font-black">Trabajos</p>
                            <p class="text-[#509295] text-base">Servicios en San Juan del Río</p>
                        </div>
                        <button onclick="fetchServices()" class="flex items-center rounded-xl h-10 px-4 bg-[#e8f2f3] text-beo text-sm font-bold border border-beo/10 hover:bg-beo/10 transition-all">
                            <span class="material-symbols-outlined text-sm mr-2">refresh</span> Refrescar
                        </button>
                    </div>
                    <div id="servicesList" class="flex flex-col gap-6"></div>
                </div>
            </div>
        </main>
    </div>

    <div id="serviceModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4 p-4 modal-animate">
            <div class="fixed inset-0 bg-slate-900/70 backdrop-blur-sm" onclick="closeModal()"></div>
            <div class="relative bg-white rounded-3xl shadow-2xl overflow-hidden max-w-2xl w-full">
                <div class="relative h-72">
                    <img id="modalImg" src="" class="w-full h-full object-cover">
                    <button onclick="closeModal()" class="absolute top-4 right-4 bg-black/50 text-white rounded-full p-2 hover:bg-black/70">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="p-8">
                    <div class="flex justify-between items-start mb-6">
                        <div class="flex-1">
                            <span id="modalCat" class="text-[10px] font-bold tracking-widest uppercase text-beo bg-beo/10 px-3 py-1 rounded-full"></span>
                            <h3 id="modalTitle" class="text-3xl font-black text-slate-900 mt-2"></h3>
                            <p id="modalLoc" class="text-slate-500 flex items-center gap-1 mt-1 text-sm font-medium">
                                <span class="material-symbols-outlined text-xs">location_on</span>
                                <span id="locText"></span>
                            </p>
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Desde</p>
                            <p id="modalPrice" class="text-2xl font-black text-beo"></p>
                        </div>
                    </div>
                    <div class="border-t border-gray-100 pt-6">
                        <h4 class="text-[10px] font-bold text-slate-400 uppercase mb-2">Descripción del servicio</h4>
                        <p id="modalDesc" class="text-slate-600 text-sm leading-relaxed mb-8"></p>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-8">
                        <button id="modalChatBtn" class="bg-primary/10 text-primary py-4 rounded-2xl font-bold hover:bg-primary/20 flex items-center justify-center gap-2 active:scale-95 transition-all">
                            <span class="material-symbols-outlined">chat</span> Contactar
                        </button>
                        <button id="modalHireBtn" class="bg-primary text-white py-4 rounded-2xl font-bold hover:brightness-110 flex items-center justify-center gap-2 active:scale-95 transition-all shadow-lg shadow-primary/20">
                            <span class="material-symbols-outlined">verified</span> Contratar Ahora
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentFilters = { categoria: '', ubicacion: '', precio: '' };
        function closeModal() { document.getElementById('serviceModal').classList.add('hidden'); }

        async function hireService(id, workerId, titulo, precio) {
            if (!confirm(`¿Estás seguro que deseas contratar el servicio "${titulo}"?`)) return;
            
            try {
                const response = await fetch('/api/services/hire', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serviceId: id, workerId, titulo, precio })
                });

                if (response.ok) {
                    alert('¡Contratación registrada! El trabajador ha sido notificado.');
                    window.location.href = '/dashboard';
                } else {
                    const err = await response.json();
                    alert('Error: ' + (err.error || 'No se pudo procesar'));
                }
            } catch (error) {
                alert('Error al conectar con el servidor');
            }
        }

        async function fetchServices() {
            const listContainer = document.getElementById('servicesList');
            const urlParams = new URLSearchParams(window.location.search);
            const q = urlParams.get('q') || '';
            const category = urlParams.get('categoria') || '';
            const location = urlParams.get('ubicacion') || '';

            try {
                let apiUrl = `/api/services?`;
                if (q) apiUrl += `q=${encodeURIComponent(q)}&`;
                if (category) apiUrl += `categoria=${encodeURIComponent(category)}&`;
                if (location) apiUrl += `ubicacion=${encodeURIComponent(location)}`;

                const response = await fetch(apiUrl);
                let services = await response.json();
                
                if (!Array.isArray(services) || services.length === 0) {
                    listContainer.innerHTML = `
                        <div class="col-span-full text-center py-20 bg-white rounded-xl border border-[#e8f2f3]">
                            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">search_off</span>
                            <p class="text-xl font-medium text-slate-500">No encontramos servicios que coincidan.</p>
                        </div>
                    `;
                    return;
                }

                listContainer.innerHTML = services.map(service => {
                    const serviceString = encodeURIComponent(JSON.stringify(service));
                    return `
                        <div class="flex flex-col md:flex-row rounded-xl border border-[#e8f2f3] bg-white overflow-hidden shadow-sm mb-4">
                            <div class="w-full md:w-80 h-56 md:h-auto bg-gray-100 flex-shrink-0">
                                <img src="${service.imageUrl || '/Images/default-avatar.png'}" class="w-full h-full object-cover" onerror="this.src='/Images/default-avatar.png';">
                            </div>
                            <div class="flex-1 p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-[9px] font-bold text-beo bg-beo/5 px-2 py-0.5 rounded uppercase">${service.categoria || 'GENERAL'}</span>
                                    <h3 class="text-[#0e1a1b] text-2xl font-black mt-1">${service.titulo}</h3>
                                    <p class="text-[#509295] text-xs font-medium flex items-center gap-1 mt-1">
                                        <span class="material-symbols-outlined text-xs">location_on</span> ${service.ubicacion || 'San Juan del Río'}
                                    </p>
                                    <p class="text-gray-500 text-sm mt-4 line-clamp-2">${service.descripcion}</p>
                                </div>
                                <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-50">
                                    <p class="text-[#0e1a1b] text-xl font-bold">$${service.precioBase} MXN</p>
                                    <button onclick="openDetails('${serviceString}')" class="bg-[#00797a] text-white px-8 h-11 rounded-xl text-sm font-bold active:scale-95 transition-all">Ver más</button>
                                </div>
                            </div>
                        </div>`;
                }).join('');
            } catch (error) { console.error('Error:', error); }
        }

        function openDetails(serviceData) {
            const s = JSON.parse(decodeURIComponent(serviceData));
            document.getElementById('modalTitle').innerText = s.titulo;
            document.getElementById('modalDesc').innerText = s.descripcion || "Sin descripción.";
            document.getElementById('modalPrice').innerText = `$${s.precioBase} MXN`;
            document.getElementById('modalCat').innerText = s.categoria || 'SERVICIO';
            document.getElementById('locText').innerText = s.ubicacion || 'San Juan del Río';
            document.getElementById('modalImg').src = s.imageUrl || '/Images/default-avatar.png';

            // REDIRECCIÓN CON ID
            document.getElementById('modalChatBtn').onclick = () => {
                if (s.workerId) { window.location.href = `/mensajes?chatWith=${s.workerId}`; }
                else { alert("ID del trabajador no encontrado."); }
            };

            // BOTOTAL DE CONTRATACIÓN
            document.getElementById('modalHireBtn').onclick = () => {
                hireService(s.id, s.workerId, s.titulo, s.precioBase);
            };

            document.getElementById('serviceModal').classList.remove('hidden');
        }
        document.addEventListener('DOMContentLoaded', fetchServices);
    </script>
    <%- include('../../Partials/footer') %>
</body>
</html>