<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>B E O - Encuentra Servicios</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="/js/tailwind-config.js"></script>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="bg-background-light dark:bg-background-dark font-display">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <%- include('../../Partials/header') %>
        
        <main class="flex-1 flex justify-center py-8">
            <div class="flex w-full max-w-[1280px] px-6 gap-8">
                
                <aside class="w-64 flex flex-col shrink-0">
                    <div class="flex flex-col gap-6 bg-white dark:bg-background-dark p-6 rounded-xl border border-[#e8f2f3] shadow-sm">
                        <h2 class="text-[#0e1a1b] text-lg font-bold">Filtros</h2>
                        
                        <div class="flex flex-col gap-2">
                            <button id="btnLocation" class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] rounded-lg transition-colors group">
                                <span class="material-symbols-outlined text-primary group-hover:scale-110">location_on</span>
                                <p class="text-[#0e1a1b] text-sm font-medium">Filtrar por Ubicación</p>
                            </button>
                        </div>

                        <div class="flex flex-col gap-2 border-t pt-4">
                            <button id="btnPrice" class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-[#e8f2f3] rounded-lg transition-colors group">
                                <span class="material-symbols-outlined text-primary group-hover:scale-110">payments</span>
                                <p class="text-[#0e1a1b] text-sm font-medium">Precio Máximo</p>
                            </button>
                        </div>

                        <div class="flex flex-col gap-2 pl-2 border-t pt-4">
                            <p class="text-xs font-bold text-gray-400 mb-2 uppercase">Oficios Populares</p>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Plomería" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Plomería</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Electricidad" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Electricidad</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Albañilería" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Albañilería</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Carpintería" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Carpintería</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Mecánica" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Mecánica</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input name="trade" value="Herrería" type="checkbox" class="rounded text-primary focus:ring-primary">
                                <span class="text-sm text-[#0e1a1b]">Herrería</span>
                            </label>
                        </div>
                    </div>
                </aside>

                <div class="flex-1 flex flex-col gap-4">
                    <div class="flex flex-wrap justify-between items-end gap-3 p-6 bg-white rounded-xl border border-[#e8f2f3] shadow-sm">
                        <div>
                            <p class="text-primary text-4xl font-black">Trabajos</p>
                            <p class="text-[#509295] text-base">Servicios en San Juan del Río</p>
                        </div>
                        <button onclick="fetchServices()" class="flex items-center rounded-xl h-10 px-4 bg-[#e8f2f3] text-primary text-sm font-bold border border-primary/10">
                            <span class="material-symbols-outlined text-sm mr-2">refresh</span> Refrescar
                        </button>
                    </div>

                    <div id="activeFiltersSection" class="flex gap-3 px-4 py-2 flex-wrap items-center">
                        <p class="text-[#509295] text-xs font-bold uppercase tracking-wider">ACTIVOS:</p>
                        <div id="chipsContainer" class="flex gap-2"></div>
                        <button onclick="clearAllFilters()" class="text-xs text-primary font-bold hover:underline">Limpiar todo</button>
                    </div>

                    <div id="servicesList" class="flex flex-col gap-6"></div>
                </div>
            </div>
        </main>
    </div>

    <script>
        let currentFilters = { categoria: '', ubicacion: '', precio: '' };

        async function fetchServices() {
            const listContainer = document.getElementById('servicesList');
            const searchParams = new URLSearchParams();
            
            // Filtros básicos para el servidor
            if (currentFilters.categoria) searchParams.append('categoria', currentFilters.categoria);
            if (currentFilters.ubicacion) searchParams.append('ubicacion', currentFilters.ubicacion);

            try {
                const response = await fetch(`/api/services?${searchParams.toString()}`);
                let services = await response.json();
                renderChips();

                // LÓGICA DE FILTRADO POR PRECIO
                if (currentFilters.precio) {
                    const max = parseFloat(currentFilters.precio);
                    services = services.filter(s => parseFloat(s.precioBase) <= max);
                }

                if (services.length === 0) {
                    listContainer.innerHTML = `<p class="p-10 text-center text-gray-400">No se encontraron servicios con estos criterios.</p>`;
                    return;
                }

                listContainer.innerHTML = services.map(service => {
                    // Mantenemos la lógica de imagen que revisará tu amigo
                    let imgUrl = service.imagenPath || 'https://placehold.co/600x400/e8f2f3/509295?text=BEO+Servicios';
                    
                    return `
                        <div class="flex flex-col md:flex-row rounded-xl border border-[#e8f2f3] bg-white overflow-hidden shadow-sm mb-4">
                            <div class="w-full md:w-80 h-56 md:h-auto bg-gray-100 flex-shrink-0">
                                <img src="${imgUrl}" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1 p-6 flex flex-col justify-between">
                                <div>
                                    <p class="text-primary text-[10px] font-bold uppercase tracking-widest">${service.categoria || 'GENERAL'}</p>
                                    <h3 class="text-[#0e1a1b] text-2xl font-black mt-1">${service.titulo}</h3>
                                    <div class="flex items-center gap-1 text-[#509295] mt-1">
                                        <span class="material-symbols-outlined text-sm">location_on</span>
                                        <span class="text-sm font-medium">${service.ubicacion || 'San Juan del Río'}</span>
                                    </div>
                                    <p class="text-gray-500 text-sm mt-4 line-clamp-2">${service.descripcion}</p>
                                </div>
                                <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-50">
                                    <p class="text-[#0e1a1b] text-xl font-bold">$${service.precioBase} MXN</p>
                                    <button class="bg-primary text-white px-8 h-11 rounded-xl text-sm font-bold">Contactar</button>
                                </div>
                            </div>
                        </div>`;
                }).join('');
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function renderChips() {
            const container = document.getElementById('chipsContainer');
            container.innerHTML = '';
            Object.keys(currentFilters).forEach(key => {
                if (currentFilters[key]) {
                    let label = key === 'precio' ? `$${currentFilters[key]}` : currentFilters[key];
                    container.innerHTML += `
                        <div class="flex items-center gap-2 bg-primary/10 border border-primary/20 px-3 py-1 rounded-full">
                            <span class="text-primary text-[11px] font-bold uppercase">${label}</span>
                            <button onclick="removeFilter('${key}')" class="material-symbols-outlined text-xs text-primary">close</button>
                        </div>`;
                }
            });
        }

        function removeFilter(type) {
            currentFilters[type] = '';
            if (type === 'categoria') {
                document.querySelectorAll('input[name="trade"]').forEach(cb => cb.checked = false);
            }
            fetchServices();
        }

        function clearAllFilters() {
            currentFilters = { categoria: '', ubicacion: '', precio: '' };
            document.querySelectorAll('input[name="trade"]').forEach(cb => cb.checked = false);
            fetchServices();
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchServices();
            
            document.querySelectorAll('input[name="trade"]').forEach(cb => {
                cb.addEventListener('change', (e) => {
                    if (e.target.checked) {
                        document.querySelectorAll('input[name="trade"]').forEach(other => { 
                            if(other !== e.target) other.checked = false; 
                        });
                        currentFilters.categoria = e.target.value;
                    } else {
                        currentFilters.categoria = '';
                    }
                    fetchServices();
                });
            });

            document.getElementById('btnLocation').addEventListener('click', () => {
                const zona = prompt("¿Qué zona buscas?");
                if (zona) { currentFilters.ubicacion = zona.trim(); fetchServices(); }
            });

            document.getElementById('btnPrice').addEventListener('click', () => {
                const precio = prompt("Introduce el presupuesto máximo:");
                if (precio && !isNaN(precio)) { 
                    currentFilters.precio = precio.trim(); 
                    fetchServices(); 
                }
            });
        });
    </script>
</body>
</html>